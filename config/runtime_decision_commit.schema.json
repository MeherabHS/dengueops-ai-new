{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    { "$ref": "#/$defs/phase1" },
    { "$ref": "#/$defs/phase2v1" },
    { "$ref": "#/$defs/phase2v2" }
  ],
  "$defs": {
    "sha": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "phase1": {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "decisionId", "assessmentId", "decisionSha256", "assessmentCommitSha256", "decisionPolicySha256", "status", "committedAt", "latestPointerUpdated", "deploymentProfileModified"],
      "properties": { "schemaVersion": { "const": "1.0" }, "decisionId": { "format": "uuid" }, "assessmentId": { "format": "uuid" }, "decisionSha256": { "$ref": "#/$defs/sha" }, "assessmentCommitSha256": { "$ref": "#/$defs/sha" }, "decisionPolicySha256": { "$ref": "#/$defs/sha" }, "status": { "const": "committed" }, "committedAt": { "format": "date-time" }, "latestPointerUpdated": { "const": false }, "deploymentProfileModified": { "const": false } }
    },
    "phase2v1": {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "decisionId", "assessmentId", "decisionSha256", "assessmentCommitSha256", "assessmentSchemaVersion", "assessmentSummarySha256", "assessmentPolicyId", "assessmentPolicyVersion", "assessmentPolicySha256", "decisionPolicyId", "decisionPolicyVersion", "decisionPolicySha256", "foldPlanSha256", "assessmentLabelledRows", "assessmentPlannedFoldCount", "status", "committedAt", "latestPointerUpdated", "deploymentProfileModified"],
      "properties": { "schemaVersion": { "const": "2.0" }, "decisionId": { "format": "uuid" }, "assessmentId": { "format": "uuid" }, "decisionSha256": { "$ref": "#/$defs/sha" }, "assessmentCommitSha256": { "$ref": "#/$defs/sha" }, "assessmentSchemaVersion": { "const": "2.0" }, "assessmentSummarySha256": { "$ref": "#/$defs/sha" }, "assessmentPolicyId": { "const": "RUNTIME.DATASET_ASSESSMENT.GOVERNANCE" }, "assessmentPolicyVersion": { "const": "p2-v1" }, "assessmentPolicySha256": { "$ref": "#/$defs/sha" }, "decisionPolicyId": { "const": "RUNTIME.INTERNAL_ONE_RUN_MODEL_DECISION" }, "decisionPolicyVersion": { "const": "p2-v1" }, "decisionPolicySha256": { "$ref": "#/$defs/sha" }, "foldPlanSha256": { "$ref": "#/$defs/sha" }, "assessmentLabelledRows": { "type": "integer", "minimum": 157 }, "assessmentPlannedFoldCount": { "type": "integer", "minimum": 52, "maximum": 68 }, "status": { "const": "committed" }, "committedAt": { "format": "date-time" }, "latestPointerUpdated": { "const": false }, "deploymentProfileModified": { "const": false } }
    },
    "phase2v2": {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "decisionId", "assessmentId", "decisionSha256", "assessmentCommitSha256", "assessmentSchemaVersion", "assessmentSummarySha256", "assessmentPolicyId", "assessmentPolicyVersion", "assessmentPolicySha256", "decisionPolicyId", "decisionPolicyVersion", "decisionPolicySha256", "foldPlanSha256", "assessmentLabelledRows", "assessmentPlannedFoldCount", "status", "committedAt", "latestPointerUpdated", "deploymentProfileModified"],
      "properties": { "schemaVersion": { "const": "2.0" }, "decisionId": { "format": "uuid" }, "assessmentId": { "format": "uuid" }, "decisionSha256": { "$ref": "#/$defs/sha" }, "assessmentCommitSha256": { "$ref": "#/$defs/sha" }, "assessmentSchemaVersion": { "const": "2.0" }, "assessmentSummarySha256": { "$ref": "#/$defs/sha" }, "assessmentPolicyId": { "const": "RUNTIME.DATASET_ASSESSMENT.GOVERNANCE" }, "assessmentPolicyVersion": { "const": "p2-v2" }, "assessmentPolicySha256": { "const": "569faeca27a4715e72085ac97c78b00f83351bd7783fc156f5bd8f626cab28b8" }, "decisionPolicyId": { "const": "RUNTIME.INTERNAL_ONE_RUN_MODEL_DECISION" }, "decisionPolicyVersion": { "const": "p2-v2" }, "decisionPolicySha256": { "$ref": "#/$defs/sha" }, "foldPlanSha256": { "$ref": "#/$defs/sha" }, "assessmentLabelledRows": { "type": "integer", "minimum": 157 }, "assessmentPlannedFoldCount": { "type": "integer", "minimum": 52, "maximum": 68 }, "status": { "const": "committed" }, "committedAt": { "format": "date-time" }, "latestPointerUpdated": { "const": false }, "deploymentProfileModified": { "const": false } }
    }
  }
}
