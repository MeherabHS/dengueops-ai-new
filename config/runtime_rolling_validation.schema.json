  "$defs": {
    "p1": {
      "uuid": {
        "type": "string",
        "format": "uuid"
      },
      "sha": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      },
      "period": {
        "type": "string",
        "pattern": "^[0-9]{4}-W[0-9]{2}$"
      },
      "modelId": {
        "enum": [
          "previous_week_naive",
          "moving_average_4w",
          "seasonal_naive_52w",
          "ridge_regression",
          "poisson_regression",
          "random_forest",
          "gradient_boosting",
          "elastic_net",
          "negative_binomial_regression",
          "extra_trees",
          "hist_gradient_boosting"
        ]
      },
      "assessmentPolicy": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "policyId",
          "policyVersion",
          "policySha256"
        ],
        "properties": {
          "policyId": {
            "const": "RUNTIME.DATASET_ASSESSMENT.GOVERNANCE"
          },
          "policyVersion": {
            "const": "p1.4d-1-v1"
          },
          "policySha256": {
            "$ref": "#/$defs/p1/sha"
          }
        }
      },
      "prediction": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "modelId",
          "foldStatus",
          "rawPrediction",
          "publishedPrediction",
          "clippingApplied",
          "signedError",
          "absoluteError",
          "squaredError",
          "failureReasonCode",
          "warningCodes",
          "runtimeSeconds"
        ],
        "properties": {
          "modelId": {
            "$ref": "#/$defs/p1/modelId"
          },
          "foldStatus": {
            "enum": [
              "success",
              "warning",
              "failed"
            ]
          },
          "rawPrediction": {
            "type": [
              "number",
              "null"
            ]
          },
          "publishedPrediction": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "clippingApplied": {
            "type": "boolean"
          },
          "signedError": {
            "type": [
              "number",
              "null"
            ]
          },
          "absoluteError": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "squaredError": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "failureReasonCode": {
            "type": [
              "string",
              "null"
            ]
          },
          "warningCodes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "runtimeSeconds": {
            "type": "number",
            "minimum": 0
          }
        }
      },
      "fold": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "foldId",
          "sequence",
          "trainingPeriod",
          "trainingRowCount",
          "embargoPeriod",
          "forecastOrigin",
          "targetPeriod",
          "actualTarget",
          "targetTrajectory",
          "featureOrderSha256",
          "trainingMatrixSha256",
          "validationMatrixSha256",
          "labelAvailabilityRule",
          "predictions"
        ],
        "properties": {
          "foldId": {
            "type": "string",
            "pattern": "^rolling-origin-[0-9]{4}-[0-9]{4}-W[0-9]{2}-to-[0-9]{4}-W[0-9]{2}$"
          },
          "sequence": {
            "type": "integer",
            "minimum": 1,
            "maximum": 68
          },
          "trainingPeriod": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "start",
              "end"
            ],
            "properties": {
              "start": {
                "$ref": "#/$defs/p1/period"
              },
              "end": {
                "$ref": "#/$defs/p1/period"
              }
            }
          },
          "trainingRowCount": {
            "type": "integer",
            "minimum": 104
          },
          "embargoPeriod": {
            "$ref": "#/$defs/p1/period"
          },
          "forecastOrigin": {
            "$ref": "#/$defs/p1/period"
          },
          "targetPeriod": {
            "$ref": "#/$defs/p1/period"
          },
          "actualTarget": {
            "type": "number",
            "minimum": 0
          },
          "targetTrajectory": {
            "enum": [
              "rising",
              "declining",
              "stable"
            ]
          },
          "featureOrderSha256": {
            "$ref": "#/$defs/p1/sha"
          },
          "trainingMatrixSha256": {
            "$ref": "#/$defs/p1/sha"
          },
          "validationMatrixSha256": {
            "$ref": "#/$defs/p1/sha"
          },
          "labelAvailabilityRule": {
            "type": "string",
            "minLength": 1
          },
          "predictions": {
            "type": "array",
            "minItems": 7,
            "maxItems": 7,
            "items": {
              "$ref": "#/$defs/p1/prediction"
            }
          }
        }
      }
    },
