            "maximumFoldCount",
            "foldSelectionRule"
          ],
          "properties": {
            "policyId": {
              "const": "RUNTIME.ASSESSMENT.DYNAMIC_EXPANDING_FOLDS"
            },
            "policyVersion": {
              "const": "p2-v1"
            },
            "trainingWindow": {
              "const": "expanding"
            },
            "initialTrainingRows": {
              "const": 104
            },
            "embargoRows": {
              "const": 1
            },
            "validationRowsPerFold": {
              "const": 1
