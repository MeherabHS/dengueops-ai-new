        "folds",
        "generatedAt",
        "labelledRows",
        "availableFoldCount",
        "foldCapApplied",
        "selectedValidationStartIndex",
        "selectedValidationEndIndex",
        "selectedEvaluationPeriod"
      ],
      "properties": {
        "schemaVersion": {
          "const": "2.0"
        },
        "assessmentId": {
          "$ref": "#/$defs/p2/uuid"
        },
        "jobId": {
          "$ref": "#/$defs/p2/uuid"
        },
        "workspaceId": {
          "$ref": "#/$defs/p2/uuid"
        },
        "datasetId": {
          "$ref": "#/$defs/p2/sha"
        },
        "deploymentId": {
          "const": "dhaka_south"
