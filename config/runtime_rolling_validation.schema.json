        "assessmentPolicy": {
          "$ref": "#/$defs/p2/assessmentPolicy"
        },
        "candidateRegistrySha256": {
          "$ref": "#/$defs/p2/sha"
        },
        "foldPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policyId",
            "policyVersion",
            "trainingWindow",
            "initialTrainingRows",
            "embargoRows",
            "validationRowsPerFold",
            "stepSizeWeeks",
            "samePlanForAllCandidates",
