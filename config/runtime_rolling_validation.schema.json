              "null"
            ]
          },
          "warningCodes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "runtimeSeconds": {
            "type": "number",
            "minimum": 0
          }
        }
      },
      "fold": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "foldId",
          "sequence",
          "trainingPeriod",
          "trainingRowCount",
          "embargoPeriod",
          "forecastOrigin",
          "targetPeriod",
          "actualTarget",
          "targetTrajectory",
          "featureOrderSha256",
          "trainingMatrixSha256",
          "validationMatrixSha256",
          "labelAvailabilityRule",
          "predictions"
        ],
        "properties": {
          "foldId": {
            "type": "string",
            "pattern": "^rolling-origin-[0-9]{4}-[0-9]{4}-W[0-9]{2}-to-[0-9]{4}-W[0-9]{2}$"
          },
          "sequence": {
            "type": "integer",
            "minimum": 1,
            "maximum": 68
          },
          "trainingPeriod": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "start",
              "end"
            ],
            "properties": {
              "start": {
                "$ref": "#/$defs/p2/period"
              },
              "end": {
                "$ref": "#/$defs/p2/period"
              }
            }
          },
          "trainingRowCount": {
            "type": "integer",
            "minimum": 104
          },
          "embargoPeriod": {
            "$ref": "#/$defs/p2/period"
          },
          "forecastOrigin": {
            "$ref": "#/$defs/p2/period"
          },
          "targetPeriod": {
            "$ref": "#/$defs/p2/period"
          },
          "actualTarget": {
            "type": "number",
            "minimum": 0
          },
          "targetTrajectory": {
            "enum": [
              "rising",
              "declining",
              "stable"
            ]
          },
          "featureOrderSha256": {
            "$ref": "#/$defs/p2/sha"
          },
          "trainingMatrixSha256": {
            "$ref": "#/$defs/p2/sha"
          },
          "validationMatrixSha256": {
            "$ref": "#/$defs/p2/sha"
          },
          "labelAvailabilityRule": {
            "type": "string",
            "minLength": 1
          },
          "predictions": {
            "type": "array",
            "minItems": 7,
            "maxItems": 10,
            "items": {
              "$ref": "#/$defs/p2/prediction"
            }
          }
        }
      }
    }
  }
