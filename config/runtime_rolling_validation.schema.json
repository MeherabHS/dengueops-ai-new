{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://dengueops.ai/schemas/runtime_rolling_validation.schema.json",
  "type":"object","additionalProperties":false,
  "required":["schemaVersion","assessmentId","jobId","workspaceId","datasetId","deploymentId","assessmentPolicy","candidateRegistrySha256","foldPolicy","foldPlanSha256","plannedFoldCount","candidateIds","featureOrderSha256","target","horizonWeeks","folds","generatedAt"],
  "properties":{
    "schemaVersion":{"const":"1.0"},"assessmentId":{"$ref":"#/$defs/uuid"},"jobId":{"$ref":"#/$defs/uuid"},"workspaceId":{"$ref":"#/$defs/uuid"},"datasetId":{"$ref":"#/$defs/sha"},"deploymentId":{"const":"dhaka_south"},
    "assessmentPolicy":{"$ref":"#/$defs/assessmentPolicy"},"candidateRegistrySha256":{"$ref":"#/$defs/sha"},
    "foldPolicy":{"type":"object","additionalProperties":false,"required":["policyId","policyVersion","trainingWindow","initialTrainingRows","embargoRows","validationRowsPerFold","stepSizeWeeks","samePlanForAllCandidates"],"properties":{"policyId":{"const":"RUNTIME.ASSESSMENT.DYNAMIC_EXPANDING_FOLDS"},"policyVersion":{"const":"p1.4d-1-v1"},"trainingWindow":{"const":"expanding"},"initialTrainingRows":{"const":104},"embargoRows":{"const":1},"validationRowsPerFold":{"const":1},"stepSizeWeeks":{"const":1},"samePlanForAllCandidates":{"const":true}}},
    "foldPlanSha256":{"$ref":"#/$defs/sha"},"plannedFoldCount":{"const":68},
    "candidateIds":{"const":["previous_week_naive","moving_average_4w","seasonal_naive_52w","ridge_regression","poisson_regression","random_forest","gradient_boosting"]},
    "featureOrderSha256":{"$ref":"#/$defs/sha"},"target":{"const":"target_cases_next_2w"},"horizonWeeks":{"const":2},
    "folds":{"type":"array","minItems":68,"maxItems":68,"items":{"$ref":"#/$defs/fold"}},"generatedAt":{"type":"string","format":"date-time"}
  },
  "$defs":{
    "uuid":{"type":"string","format":"uuid"},"sha":{"type":"string","pattern":"^[a-f0-9]{64}$"},"period":{"type":"string","pattern":"^[0-9]{4}-W[0-9]{2}$"},
    "modelId":{"enum":["previous_week_naive","moving_average_4w","seasonal_naive_52w","ridge_regression","poisson_regression","random_forest","gradient_boosting"]},
    "assessmentPolicy":{"type":"object","additionalProperties":false,"required":["policyId","policyVersion","policySha256"],"properties":{"policyId":{"const":"RUNTIME.DATASET_ASSESSMENT.GOVERNANCE"},"policyVersion":{"const":"p1.4d-1-v1"},"policySha256":{"$ref":"#/$defs/sha"}}},
    "prediction":{"type":"object","additionalProperties":false,"required":["modelId","foldStatus","rawPrediction","publishedPrediction","clippingApplied","signedError","absoluteError","squaredError","failureReasonCode","warningCodes","runtimeSeconds"],"properties":{"modelId":{"$ref":"#/$defs/modelId"},"foldStatus":{"enum":["success","warning","failed"]},"rawPrediction":{"type":["number","null"]},"publishedPrediction":{"type":["number","null"],"minimum":0},"clippingApplied":{"type":"boolean"},"signedError":{"type":["number","null"]},"absoluteError":{"type":["number","null"],"minimum":0},"squaredError":{"type":["number","null"],"minimum":0},"failureReasonCode":{"type":["string","null"]},"warningCodes":{"type":"array","items":{"type":"string","minLength":1}},"runtimeSeconds":{"type":"number","minimum":0}}},
    "fold":{"type":"object","additionalProperties":false,"required":["foldId","sequence","trainingPeriod","trainingRowCount","embargoPeriod","forecastOrigin","targetPeriod","actualTarget","targetTrajectory","featureOrderSha256","trainingMatrixSha256","validationMatrixSha256","labelAvailabilityRule","predictions"],"properties":{"foldId":{"type":"string","pattern":"^rolling-origin-[0-9]{4}-[0-9]{4}-W[0-9]{2}-to-[0-9]{4}-W[0-9]{2}$"},"sequence":{"type":"integer","minimum":1,"maximum":68},"trainingPeriod":{"type":"object","additionalProperties":false,"required":["start","end"],"properties":{"start":{"$ref":"#/$defs/period"},"end":{"$ref":"#/$defs/period"}}},"trainingRowCount":{"type":"integer","minimum":104},"embargoPeriod":{"$ref":"#/$defs/period"},"forecastOrigin":{"$ref":"#/$defs/period"},"targetPeriod":{"$ref":"#/$defs/period"},"actualTarget":{"type":"number","minimum":0},"targetTrajectory":{"enum":["rising","declining","stable"]},"featureOrderSha256":{"$ref":"#/$defs/sha"},"trainingMatrixSha256":{"$ref":"#/$defs/sha"},"validationMatrixSha256":{"$ref":"#/$defs/sha"},"labelAvailabilityRule":{"type":"string","minLength":1},"predictions":{"type":"array","minItems":7,"maxItems":7,"items":{"$ref":"#/$defs/prediction"}}}}
  }
}
