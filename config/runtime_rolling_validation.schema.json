{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "assessmentId",
        "jobId",
        "workspaceId",
        "datasetId",
        "deploymentId",
        "assessmentPolicy",
        "candidateRegistrySha256",
