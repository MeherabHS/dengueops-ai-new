          "policyId": {
            "const": "RUNTIME.DATASET_ASSESSMENT.GOVERNANCE"
          },
          "policyVersion": {"enum": ["p2-v1", "p2-v2"]},
          "policySha256": {
            "$ref": "#/$defs/p2/sha"
          }
        }
      },
      "prediction": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "modelId",
          "foldStatus",
          "rawPrediction",
          "publishedPrediction",
          "clippingApplied",
          "signedError",
          "absoluteError",
          "squaredError",
          "failureReasonCode",
          "warningCodes",
          "runtimeSeconds"
        ],
        "properties": {
          "modelId": {
            "$ref": "#/$defs/p2/modelId"
          },
          "foldStatus": {
            "enum": [
              "success",
              "warning",
