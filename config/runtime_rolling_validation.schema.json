          "properties": {
            "policyId": {
              "const": "RUNTIME.ASSESSMENT.DYNAMIC_EXPANDING_FOLDS"
            },
            "policyVersion": {
              "const": "p1.4d-1-v1"
            },
            "trainingWindow": {
              "const": "expanding"
            },
            "initialTrainingRows": {
              "const": 104
            },
            "embargoRows": {
              "const": 1
            },
            "validationRowsPerFold": {
              "const": 1
            },
            "stepSizeWeeks": {
              "const": 1
            },
            "samePlanForAllCandidates": {
              "const": true
            }
          }
        },
        "foldPlanSha256": {
          "$ref": "#/$defs/p1/sha"
        },
        "plannedFoldCount": {
          "const": 68
        },
        "candidateIds": {
          "oneOf": [
            {"const": ["previous_week_naive", "moving_average_4w", "seasonal_naive_52w", "ridge_regression", "poisson_regression", "random_forest", "gradient_boosting"]},
            {"const": ["moving_average_4w", "seasonal_naive_52w", "ridge_regression", "poisson_regression", "random_forest", "gradient_boosting", "elastic_net", "negative_binomial_regression", "extra_trees", "hist_gradient_boosting"]}
          ]
        },
        "featureOrderSha256": {
          "$ref": "#/$defs/p1/sha"
        },
        "target": {
          "const": "target_cases_next_2w"
        },
        "horizonWeeks": {
          "const": 2
        },
        "folds": {
          "type": "array",
          "minItems": 68,
          "maxItems": 68,
          "items": {
            "$ref": "#/$defs/p1/fold"
          }
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "assessmentId",
        "jobId",
