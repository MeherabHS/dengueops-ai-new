          },
          "clippingApplied": {
            "type": "boolean"
          },
          "signedError": {
            "type": [
              "number",
              "null"
            ]
          },
          "absoluteError": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "squaredError": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "failureReasonCode": {
            "type": [
