{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://dengueops.ai/schemas/runtime_assessment_commit.schema.json","type":"object","additionalProperties":false,
  "required":["schemaVersion","assessmentId","jobId","workspaceId","datasetId","deploymentId","workflowMode","sourceType","status","validationRecordSha256","assessmentPolicySha256","candidateRegistrySha256","foldPlanSha256","artifactHashes","summaryPublishedLast","prohibitedArtifactsAbsent","latestPointerUpdated","committedAt"],
