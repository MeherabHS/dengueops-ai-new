  "$defs": {
    "p1": {
      "uuid": {
        "type": "string",
        "format": "uuid"
      },
      "sha": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      },
      "model": {
        "enum": [
          "previous_week_naive",
          "moving_average_4w",
          "seasonal_naive_52w",
          "ridge_regression",
          "poisson_regression",
          "random_forest",
          "gradient_boosting"
        ]
      }
    },
    "p2": {
      "uuid": {
        "type": "string",
        "format": "uuid"
      },
      "sha": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      },
      "model": {
        "enum": [
          "previous_week_naive",
          "moving_average_4w",
          "seasonal_naive_52w",
          "ridge_regression",
          "poisson_regression",
          "random_forest",
          "gradient_boosting",
          "elastic_net",
          "negative_binomial_regression",
          "extra_trees",
          "hist_gradient_boosting"
        ]
