{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "assessmentId",
        "jobId",
        "workspaceId",
        "datasetId",
        "deploymentId",
        "assessmentPolicySha256",
        "comparisonSha256",
        "foldPlanSha256",
        "candidateRegistrySha256",
        "recommendationPolicy",
        "technicalWinnerModelId",
        "winnerParameterSha256",
        "recommendationStatus",
        "recommendationStrength",
        "recommendationReason",
        "candidateSetStatus",
        "baselineRequirementSatisfied",
        "learnedModelRequirementSatisfied",
        "evidenceInputs",
        "limitations",
        "approvalRequired",
        "approvalEnabled",
        "approvalStatus",
        "adoptionStatus",
        "automaticAdoptionAllowed",
        "generatedAt"
      ],
      "properties": {
        "schemaVersion": {
          "const": "1.0"
        },
        "assessmentId": {
          "$ref": "#/$defs/p1/uuid"
        },
        "jobId": {
          "$ref": "#/$defs/p1/uuid"
        },
        "workspaceId": {
          "$ref": "#/$defs/p1/uuid"
        },
        "datasetId": {
          "$ref": "#/$defs/p1/sha"
        },
        "deploymentId": {
          "const": "dhaka_south"
        },
        "assessmentPolicySha256": {
          "$ref": "#/$defs/p1/sha"
        },
        "comparisonSha256": {
          "$ref": "#/$defs/p1/sha"
        },
        "foldPlanSha256": {
          "$ref": "#/$defs/p1/sha"
        },
        "candidateRegistrySha256": {
          "$ref": "#/$defs/p1/sha"
        },
        "recommendationPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policyId",
            "policyVersion",
            "strengthThresholdStatus"
          ],
          "properties": {
            "policyId": {
              "const": "RUNTIME.ASSESSMENT.RECOMMENDATION_STRENGTH"
            },
            "policyVersion": {
              "const": "p1.4d-1-v1"
            },
            "strengthThresholdStatus": {
              "const": "not_governed"
            }
          }
        },
        "technicalWinnerModelId": {
          "anyOf": [
            {
              "$ref": "#/$defs/p1/model"
            },
            {
              "type": "null"
            }
          ]
        },
        "winnerParameterSha256": {
          "anyOf": [
            {
              "$ref": "#/$defs/p1/sha"
            },
            {
              "type": "null"
            }
          ]
        },
        "recommendationStatus": {
          "enum": [
            "evidence_only",
            "no_recommendation"
          ]
        },
        "recommendationStrength": {
          "const": "not_available"
        },
        "recommendationReason": {
          "type": "string",
          "minLength": 1
        },
        "candidateSetStatus": {
          "enum": [
            "complete_candidate_set",
            "partial_candidate_set",
            "insufficient_candidate_breadth"
          ]
        },
        "baselineRequirementSatisfied": {
          "type": "boolean"
        },
        "learnedModelRequirementSatisfied": {
          "type": "boolean"
        },
        "evidenceInputs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "winnerMae",
            "runnerUpMae",
            "absoluteMaeGap",
            "relativeMaeGap",
            "successfulFoldRatio",
            "failedFoldCount",
            "clippingCount",
            "warningCount",
            "candidateBreadth",
            "tieBreakStageUsed",
            "datasetFoldCount"
          ],
          "properties": {
            "winnerMae": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            },
            "runnerUpMae": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            },
            "absoluteMaeGap": {
              "type": [
                "number",
                "null"
              ]
            },
            "relativeMaeGap": {
              "type": [
                "number",
                "null"
              ]
            },
            "successfulFoldRatio": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0,
              "maximum": 1
            },
            "failedFoldCount": {
              "type": "integer",
              "minimum": 0
            },
            "clippingCount": {
              "type": "integer",
              "minimum": 0
            },
            "warningCount": {
              "type": "integer",
              "minimum": 0
            },
            "candidateBreadth": {
              "type": "integer",
              "minimum": 0,
              "maximum": 7
            },
            "tieBreakStageUsed": {
              "type": [
                "string",
                "null"
              ]
            },
            "datasetFoldCount": {
              "const": 68
            }
          }
        },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "approvalRequired": {
          "const": true
        },
        "approvalEnabled": {
          "const": false
        },
        "approvalStatus": {
          "const": "approval_pending"
        },
        "adoptionStatus": {
          "const": "not_adopted"
        },
        "automaticAdoptionAllowed": {
          "const": false
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
