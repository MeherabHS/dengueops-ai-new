{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dengueops.local/schemas/rolling_validation.schema.json",
  "title": "DengueOps rolling-origin validation artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["validation_schema_version", "validation_version", "availability_status", "validation_method", "primary_validation", "initial_training_window", "horizon_weeks", "step_weeks", "fold_count", "label_availability_policy", "model_id", "model_version", "model_parameters", "model_parameters_sha256", "feature_names", "feature_formula_ids", "feature_order_sha256", "target", "folds", "aggregate_metrics", "baseline_metrics", "model_comparison", "variability_summary", "period_summary", "native_importance_stability", "permutation_stability_status", "limitations", "deployment_gate", "data_mode", "observed_data_mode", "formula_registry_version", "formula_registry_sha256", "deployment_profile_id", "deployment_profile_sha256", "evidence_registry_sha256", "model_card_id", "model_card_version", "provenance", "generated_at"],
  "properties": {
    "validation_schema_version": {"const": "1.0"},
    "validation_version": {"const": "p1.1-v1"},
    "availability_status": {"const": "generated"},
    "validation_method": {"const": "expanding_window_rolling_origin"},
    "primary_validation": {"const": true},
    "initial_training_window": {"const": 104},
    "horizon_weeks": {"const": 2},
    "step_weeks": {"const": 1},
    "fold_count": {"const": 68},
    "label_availability_policy": {"const": "target_label_available_when_target_period_is_at_or_before_forecast_origin"},
    "model_id": {"type": "string"}, "model_version": {"type": "string"},
    "model_parameters": {"type": "object"}, "model_parameters_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "feature_names": {"type": "array", "minItems": 18, "maxItems": 18, "uniqueItems": true, "items": {"type": "string"}},
    "feature_formula_ids": {"type": "array", "items": {"type": "string"}},
    "feature_order_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "target": {"const": "target_cases_next_2w"},
    "folds": {"type": "array", "minItems": 68, "maxItems": 68, "items": {"type": "object"}},
    "aggregate_metrics": {"type": "object"}, "baseline_metrics": {"type": "object"}, "model_comparison": {"type": "array"},
    "variability_summary": {"type": "object"}, "period_summary": {"type": "object"}, "native_importance_stability": {"type": "object"},
    "permutation_stability_status": {"const": "not_evaluated_single_row_folds"}, "limitations": {"type": "array", "items": {"type": "string"}},
    "deployment_gate": {"const": "benchmark_only"}, "data_mode": {"const": "synthetic_capability_demonstration"}, "observed_data_mode": {"const": "synthetic"},
    "formula_registry_version": {"type": "string", "pattern": "^p[0-9]+\\.[0-9]+[a-z]?-v[0-9]+$"}, "formula_registry_sha256": {"type": "string"},
    "formula_ids_used": {"type": "array"}, "formula_validation_status": {"type": "string"}, "formula_policy": {"type": "object"},
    "deployment_profile_id": {"type": ["string", "null"]}, "deployment_profile_sha256": {"type": ["string", "null"]},
    "evidence_registry_sha256": {"type": "string"}, "model_card_id": {"type": ["string", "null"]}, "model_card_version": {"type": ["string", "null"]},
    "provenance": {"type": "object"}, "generated_at": {"type": "string"}
  }
}
