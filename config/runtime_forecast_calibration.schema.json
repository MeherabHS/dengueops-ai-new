{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "runId", "jobId", "datasetId", "deploymentProfileId", "policyId", "policyVersion", "policySha256", "modelId", "modelFamily", "modelParametersSha256", "candidateRegistrySha256", "featureOrder", "featureOrderSha256", "targetColumn", "forecastHorizonWeeks", "initialTrainingRows", "embargoRows", "foldStepRows", "requiredResidualCount", "calibrationWarmupFoldCount", "nominalCoverage", "calibrationMethod", "uncertaintyMethod", "uncertaintyMethodVersion", "calibrationStatus", "residualCount", "foldPlanSha256", "finalQuantileRank", "finalQuantileValue", "historicalCoverage", "coveredFoldCount", "evaluatedFoldCount", "lowerMissCount", "upperMissCount", "intervalWidthSummary", "generatedAt", "limitations", "folds"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "runId": {"format": "uuid"}, "jobId": {"format": "uuid"}, "datasetId": {"$ref": "#/$defs/sha"},
    "deploymentProfileId": {"const": "dhaka_south"},
    "policyId": {"const": "RUNTIME.QUICK_FORECAST.COMPATIBILITY"}, "policyVersion": {"const": "p1.4f-v1"}, "policySha256": {"$ref": "#/$defs/sha"},
    "modelId": {"const": "random_forest"}, "modelFamily": {"const": "RandomForestRegressor"},
    "modelParametersSha256": {"$ref": "#/$defs/sha"}, "candidateRegistrySha256": {"$ref": "#/$defs/sha"},
    "featureOrder": {"type": "array", "const": ["rainfall_lag_2w", "rainfall_lag_4w", "temp_lag_2w", "temp_lag_4w", "humidity_lag_2w", "humidity_lag_4w", "cases_lag_1w", "cases_lag_2w", "cases_lag_4w", "cases_rolling_3w", "cases_rolling_4w", "cases_rolling_8w", "growth_rate_1w", "growth_rate_2w", "epi_week_sin", "epi_week_cos", "monsoon_flag", "post_monsoon_flag"]},
    "featureOrderSha256": {"$ref": "#/$defs/sha"}, "targetColumn": {"const": "target_cases_next_2w"}, "forecastHorizonWeeks": {"const": 2},
    "initialTrainingRows": {"const": 104}, "embargoRows": {"const": 1}, "foldStepRows": {"const": 1},
    "requiredResidualCount": {"const": 68}, "calibrationWarmupFoldCount": {"const": 20}, "nominalCoverage": {"const": 0.9},
    "calibrationMethod": {"const": "prequential_expanding_window_prior_residuals_only"},
    "uncertaintyMethod": {"const": "prequential_expanding_absolute_residual_quantile"}, "uncertaintyMethodVersion": {"const": "p1.3-v1"},
    "calibrationStatus": {"enum": ["available", "pending_dataset_specific_calibration"]},
    "residualCount": {"type": "integer", "minimum": 0, "maximum": 68}, "foldPlanSha256": {"$ref": "#/$defs/sha"},
    "finalQuantileRank": {"type": ["integer", "null"], "minimum": 1}, "finalQuantileValue": {"type": ["number", "null"], "minimum": 0},
    "historicalCoverage": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "coveredFoldCount": {"type": ["integer", "null"], "minimum": 0}, "evaluatedFoldCount": {"type": ["integer", "null"], "minimum": 0},
    "lowerMissCount": {"type": ["integer", "null"], "minimum": 0}, "upperMissCount": {"type": ["integer", "null"], "minimum": 0},
    "intervalWidthSummary": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/widths"}]},
    "generatedAt": {"format": "date-time"}, "limitations": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 1}},
    "folds": {"type": "array", "maxItems": 68, "items": {"$ref": "#/$defs/fold"}}
  },
  "allOf": [
    {"if": {"properties": {"calibrationStatus": {"const": "available"}}}, "then": {"properties": {"residualCount": {"const": 68}, "finalQuantileRank": {"const": 63}, "finalQuantileValue": {"type": "number", "minimum": 0}, "historicalCoverage": {"type": "number", "minimum": 0, "maximum": 1}, "coveredFoldCount": {"type": "integer", "minimum": 0, "maximum": 48}, "evaluatedFoldCount": {"const": 48}, "lowerMissCount": {"type": "integer", "minimum": 0, "maximum": 48}, "upperMissCount": {"type": "integer", "minimum": 0, "maximum": 48}, "intervalWidthSummary": {"$ref": "#/$defs/widths"}, "folds": {"type": "array", "minItems": 68, "maxItems": 68}}}},
    {"if": {"properties": {"calibrationStatus": {"const": "pending_dataset_specific_calibration"}}}, "then": {"properties": {"residualCount": {"const": 0}, "finalQuantileRank": {"type": "null"}, "finalQuantileValue": {"type": "null"}, "historicalCoverage": {"type": "null"}, "coveredFoldCount": {"type": "null"}, "evaluatedFoldCount": {"type": "null"}, "lowerMissCount": {"type": "null"}, "upperMissCount": {"type": "null"}, "intervalWidthSummary": {"type": "null"}, "folds": {"type": "array", "maxItems": 0}}}}
  ],
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "widths": {"type": "object", "additionalProperties": false, "required": ["average", "median", "minimum", "maximum"], "properties": {"average": {"type": "number", "minimum": 0}, "median": {"type": "number", "minimum": 0}, "minimum": {"type": "number", "minimum": 0}, "maximum": {"type": "number", "minimum": 0}}},
    "fold": {"type": "object", "additionalProperties": false, "required": ["foldId", "foldSequence", "originPeriod", "targetPeriod", "trainingRowCount", "trainingMatrixSha256", "validationMatrixSha256", "actualTarget", "rawPrediction", "signedResidual", "absoluteResidual"], "properties": {"foldId": {"type": "string", "minLength": 1}, "foldSequence": {"type": "integer", "minimum": 1, "maximum": 68}, "originPeriod": {"type": "string", "pattern": "^[0-9]{4}-W[0-9]{2}$"}, "targetPeriod": {"type": "string", "pattern": "^[0-9]{4}-W[0-9]{2}$"}, "trainingRowCount": {"type": "integer", "minimum": 104}, "trainingMatrixSha256": {"$ref": "#/$defs/sha"}, "validationMatrixSha256": {"$ref": "#/$defs/sha"}, "actualTarget": {"type": "number", "minimum": 0}, "rawPrediction": {"type": "number", "minimum": 0}, "signedResidual": {"type": "number"}, "absoluteResidual": {"type": "number", "minimum": 0}}}
  }
}
