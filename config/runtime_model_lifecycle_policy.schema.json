{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dengueops.ai/schemas/runtime_model_lifecycle_policy.schema.json",
  "oneOf": [
    { "$ref": "#/$defs/phase2v1" },
    { "$ref": "#/$defs/phase2v2" }
  ],
  "$defs": {
    "sha": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "phase2v1": {
      "type": "object",
      "required": ["policy_id", "policy_version", "policy_status", "policy_sha256", "deployment_id"],
      "properties": {
        "policy_id": { "const": "RUNTIME.MODEL_LIFECYCLE.DECISION" },
        "policy_version": { "const": "p2-v1" }
      }
    },
    "phase2v2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion", "policyId", "policyVersion", "policyStatus", "policySha256",
        "deploymentId", "allowedAssessmentPolicyVersion", "allowedAssessmentPolicySha256",
        "allowedDecisionPolicyVersion", "allowedDecisionPolicySha256",
        "allowedQuickForecastPolicyVersion", "allowedQuickForecastPolicySha256",
        "candidateRegistrySha256", "featureOrderSha256", "allowedCandidateIds",
        "allowedActions", "baselineAssignmentAllowed", "diagnosticAssignmentAllowed",
        "automaticPromotionAllowed", "automaticRollbackAllowed", "automaticRetentionAllowed",
        "operatorDecisionRequired"
      ],
      "properties": {
        "schemaVersion": { "const": "2.0" },
        "policyId": { "const": "RUNTIME.MODEL_LIFECYCLE.DECISION" },
        "policyVersion": { "const": "p2-v2" },
        "policyStatus": { "const": "active" },
        "policySha256": { "$ref": "#/$defs/sha" },
        "deploymentId": { "const": "dhaka_south" },
        "allowedAssessmentPolicyVersion": { "const": "p2-v2" },
        "allowedAssessmentPolicySha256": { "$ref": "#/$defs/sha" },
        "allowedDecisionPolicyVersion": { "const": "p2-v2" },
        "allowedDecisionPolicySha256": { "$ref": "#/$defs/sha" },
        "allowedQuickForecastPolicyVersion": { "const": "p2-v1" },
        "allowedQuickForecastPolicySha256": { "$ref": "#/$defs/sha" },
        "candidateRegistrySha256": { "const": "74cb3635c5e211874ee5ad23196fc95bfdfbdb5c6438cc3d060f0b9ff49acfa0" },
        "featureOrderSha256": { "const": "aeccbe517da452e1132f08c02599418523fb003280b11ff9cda66cfb3aa55a85" },
        "allowedCandidateIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowedActions": { "const": ["assign_selected_model"] },
        "baselineAssignmentAllowed": { "const": false },
        "diagnosticAssignmentAllowed": { "const": false },
        "automaticPromotionAllowed": { "const": false },
        "automaticRollbackAllowed": { "const": false },
        "automaticRetentionAllowed": { "const": false },
        "operatorDecisionRequired": { "const": true }
      }
    }
  }
}
