{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dengueops.local/schemas/selected_model_explainability.schema.json",
  "title": "DengueOps Selected-Model Explainability",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "selected_model_explainability_schema_version", "selected_model_explainability_version",
    "availability_status", "selected_model_id", "model_family", "estimator_library",
    "estimator_library_version", "model_parameters", "adopted_model_parameters_sha256",
    "estimator_role", "target", "forecast_horizon", "feature_names", "feature_formula_ids",
    "feature_order_sha256", "training_period", "validation_period", "training_rows",
    "validation_rows", "validation_matrix_sha256", "evaluation_split", "importance_methods",
    "native_importance", "permutation_importance", "permutation_std", "permutation_settings",
    "feature_ranking", "negative_importance_policy", "causal_interpretation_allowed",
    "rolling_importance_stability_status", "limitations", "deployment_id", "deployment_gate",
    "data_mode", "candidate_registry_sha256", "comparison_artifact_sha256",
    "adoption_status", "adoption_policy_version", "formula_registry_version",
    "formula_registry_sha256", "deployment_profile_sha256", "evidence_registry_sha256",
    "provenance", "generated_at"
  ],
  "properties": {
    "selected_model_explainability_schema_version": {"const": "1.0"},
    "selected_model_explainability_version": {"const": "p1.2b-v1"},
    "availability_status": {"const": "generated"},
    "selected_model_id": {"const": "random_forest"},
    "model_family": {"const": "RandomForestRegressor"},
    "estimator_library": {"const": "scikit-learn"},
    "estimator_library_version": {"$ref": "#/$defs/nonEmpty"},
    "model_parameters": {"type": "object", "minProperties": 1},
    "adopted_model_parameters_sha256": {"$ref": "#/$defs/sha256"},
    "estimator_role": {"const": "selected_model_chronological_holdout_validation_instance"},
    "target": {"const": "target_cases_next_2w"},
    "forecast_horizon": {"type": "object", "additionalProperties": false, "required": ["value", "unit"], "properties": {"value": {"const": 2}, "unit": {"const": "weeks"}}},
    "feature_names": {"$ref": "#/$defs/features"},
    "feature_formula_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmpty"}},
    "feature_order_sha256": {"$ref": "#/$defs/sha256"},
    "training_period": {"$ref": "#/$defs/periodRange"},
    "validation_period": {"$ref": "#/$defs/periodRange"},
    "training_rows": {"const": 138},
    "validation_rows": {"const": 35},
    "validation_matrix_sha256": {"$ref": "#/$defs/sha256"},
    "evaluation_split": {"const": "legacy_final_chronological_20_percent"},
    "importance_methods": {"const": ["native_random_forest_impurity_importance", "holdout_permutation_importance"]},
    "native_importance": {"$ref": "#/$defs/nonnegativeImportance"},
    "permutation_importance": {"$ref": "#/$defs/importance"},
    "permutation_std": {"$ref": "#/$defs/nonnegativeImportance"},
    "permutation_settings": {"type": "object", "additionalProperties": false, "required": ["scoring", "n_repeats", "random_state", "n_jobs", "max_samples"], "properties": {"scoring": {"const": "neg_mean_absolute_error"}, "n_repeats": {"const": 20}, "random_state": {"const": 42}, "n_jobs": {"const": 1}, "max_samples": {"const": 1.0}}},
    "feature_ranking": {"type": "array", "minItems": 18, "maxItems": 18, "items": {"$ref": "#/$defs/ranking"}},
    "negative_importance_policy": {"$ref": "#/$defs/nonEmpty"},
    "causal_interpretation_allowed": {"const": false},
    "rolling_importance_stability_status": {"const": "not_evaluated_across_temporal_folds"},
    "limitations": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/nonEmpty"}},
    "deployment_id": {"const": "dhaka_south"},
    "deployment_gate": {"const": "benchmark_only"},
    "data_mode": {"const": "synthetic_capability_demonstration"},
    "candidate_registry_sha256": {"$ref": "#/$defs/sha256"},
    "comparison_artifact_sha256": {"$ref": "#/$defs/sha256"},
    "adoption_status": {"const": "adopted_p1.2b"},
    "adoption_policy_version": {"const": "p1.2b-v1"},
    "formula_registry_version": {"const": "p1.3-v1"},
    "formula_registry_sha256": {"$ref": "#/$defs/sha256"},
    "deployment_profile_sha256": {"$ref": "#/$defs/sha256"},
    "evidence_registry_sha256": {"$ref": "#/$defs/sha256"},
    "provenance": {"type": "object", "minProperties": 1},
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "period": {"type": "object", "additionalProperties": false, "required": ["epi_year", "epi_week"], "properties": {"epi_year": {"type": "integer"}, "epi_week": {"type": "integer", "minimum": 1, "maximum": 52}}},
    "periodRange": {"type": "object", "additionalProperties": false, "required": ["start", "end"], "properties": {"start": {"$ref": "#/$defs/period"}, "end": {"$ref": "#/$defs/period"}}},
    "features": {"type": "array", "minItems": 18, "maxItems": 18, "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmpty"}},
    "importance": {"type": "array", "minItems": 18, "maxItems": 18, "items": {"type": "number"}},
    "nonnegativeImportance": {"type": "array", "minItems": 18, "maxItems": 18, "items": {"type": "number", "minimum": 0}},
    "ranking": {"type": "object", "additionalProperties": false, "required": ["feature_name", "feature_index", "native_importance", "permutation_mean", "permutation_standard_deviation", "permutation_is_negative"], "properties": {"feature_name": {"$ref": "#/$defs/nonEmpty"}, "feature_index": {"type": "integer", "minimum": 0, "maximum": 17}, "native_importance": {"type": "number", "minimum": 0}, "permutation_mean": {"type": "number"}, "permutation_standard_deviation": {"type": "number", "minimum": 0}, "permutation_is_negative": {"type": "boolean"}}}
  }
}
