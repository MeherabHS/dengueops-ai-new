      "properties": {
        "schemaVersion": {"const": "1.0"}, "runId": {"format": "uuid"}, "jobId": {"format": "uuid"}, "datasetId": {"$ref": "#/$defs/sha"}, "deploymentId": {"const": "dhaka_south"}, "workflowMode": {"const": "approved_assessment_forecast"}, "sourceType": {"const": "uploaded"}, "decisionId": {"format": "uuid"}, "decisionCommitSha256": {"$ref": "#/$defs/sha"}, "assessmentId": {"format": "uuid"}, "assessmentCommitSha256": {"$ref": "#/$defs/sha"}, "authorizationId": {"format": "uuid"}, "selectedModelId": {"type": "string"}, "selectedModelParameterSha256": {"$ref": "#/$defs/sha"}, "decisionScope": {"const": "one_run"}, "deploymentModelAdopted": {"const": false}, "status": {"const": "committed"}, "artifactHashes": {"type": "object", "minProperties": 8, "additionalProperties": {"$ref": "#/$defs/sha"}}, "modelCardPublishedLast": {"const": true}, "prohibitedArtifactsAbsent": {"const": true}, "committedAt": {"format": "date-time"}
      }
    },
    {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "runId", "jobId", "datasetId", "deploymentId", "workflowMode", "sourceType", "decisionId", "decisionCommitSha256", "assessmentId", "assessmentCommitSha256", "authorizationId", "authorizationCommitSha256", "assessmentPolicy", "decisionPolicy", "candidateRegistrySha256", "selectedModelId", "selectedModelParameterSha256", "technicalWinnerModelId", "technicalWinnerParameterSha256", "assessmentLabelledRows", "assessmentPlannedFoldCount", "successfulFolds", "failedFolds", "foldPlanSha256", "selectedEvaluationPeriod", "trainingRowCount", "trainingPeriod", "featureMatrixSha256", "featureOrderSha256", "target", "horizonWeeks", "forecastRaw", "forecastReported", "forecastOutputSha256", "modelCardSha256", "runRecordSha256", "decisionScope", "deploymentModelAdopted", "status", "artifactHashes", "modelCardPublishedLast", "prohibitedArtifactsAbsent", "completeReconciliation", "committedAt"],
      "properties": {
        "schemaVersion": {"const": "2.0"}, "runId": {"format": "uuid"}, "jobId": {"format": "uuid"}, "datasetId": {"$ref": "#/$defs/sha"}, "deploymentId": {"const": "dhaka_south"}, "workflowMode": {"const": "approved_assessment_forecast"}, "sourceType": {"const": "uploaded"}, "decisionId": {"format": "uuid"}, "decisionCommitSha256": {"$ref": "#/$defs/sha"}, "assessmentId": {"format": "uuid"}, "assessmentCommitSha256": {"$ref": "#/$defs/sha"}, "authorizationId": {"format": "uuid"}, "authorizationCommitSha256": {"$ref": "#/$defs/sha"}, "assessmentPolicy": {"$ref": "#/$defs/policy"}, "decisionPolicy": {"$ref": "#/$defs/policy"}, "candidateRegistrySha256": {"$ref": "#/$defs/sha"}, "selectedModelId": {"enum": ["ridge_regression", "poisson_regression", "random_forest", "gradient_boosting"]}, "selectedModelParameterSha256": {"$ref": "#/$defs/sha"}, "technicalWinnerModelId": {"type": ["string", "null"]}, "technicalWinnerParameterSha256": {"anyOf": [{"$ref": "#/$defs/sha"}, {"type": "null"}]}, "assessmentLabelledRows": {"type": "integer", "minimum": 157}, "assessmentPlannedFoldCount": {"type": "integer", "minimum": 52, "maximum": 68}, "successfulFolds": {"type": "integer", "minimum": 52, "maximum": 68}, "failedFolds": {"const": 0}, "foldPlanSha256": {"$ref": "#/$defs/sha"}, "selectedEvaluationPeriod": {"$ref": "#/$defs/range"}, "trainingRowCount": {"type": "integer", "minimum": 157}, "trainingPeriod": {"$ref": "#/$defs/range"}, "featureMatrixSha256": {"$ref": "#/$defs/sha"}, "featureOrderSha256": {"$ref": "#/$defs/sha"}, "target": {"const": "target_cases_next_2w"}, "horizonWeeks": {"const": 2}, "forecastRaw": {"type": "number"}, "forecastReported": {"type": "integer", "minimum": 0}, "forecastOutputSha256": {"$ref": "#/$defs/sha"}, "modelCardSha256": {"$ref": "#/$defs/sha"}, "runRecordSha256": {"$ref": "#/$defs/sha"}, "decisionScope": {"const": "one_run"}, "deploymentModelAdopted": {"const": false}, "status": {"const": "committed"}, "artifactHashes": {"type": "object", "minProperties": 8, "additionalProperties": {"$ref": "#/$defs/sha"}}, "modelCardPublishedLast": {"const": true}, "prohibitedArtifactsAbsent": {"const": true}, "completeReconciliation": {"const": true}, "committedAt": {"format": "date-time"}
