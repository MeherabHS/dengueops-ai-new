{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "runId", "jobId", "datasetId", "deploymentId", "workflowMode", "sourceType", "decision", "assessment", "authorization", "model", "features", "target", "horizonWeeks", "training", "comparisonPerformed", "recommendationStrength", "decisionScope", "deploymentModelAdopted", "operatorType", "institutionalApproval", "uncertaintyStatus", "preparednessStatus", "inputHashes", "artifactHashes", "commitReadiness", "intendedUse", "limitations", "generatedAt"],
      "properties": {
        "schemaVersion": {"const": "1.0"}, "runId": {"format": "uuid"}, "jobId": {"format": "uuid"}, "datasetId": {"$ref": "#/$defs/sha"}, "deploymentId": {"const": "dhaka_south"}, "workflowMode": {"const": "approved_assessment_forecast"}, "sourceType": {"const": "uploaded"}, "decision": {"type": "object", "minProperties": 4}, "assessment": {"type": "object", "minProperties": 4}, "authorization": {"type": "object", "minProperties": 2}, "model": {"type": "object", "minProperties": 5}, "features": {"type": "object", "minProperties": 2}, "target": {"const": "target_cases_next_2w"}, "horizonWeeks": {"const": 2}, "training": {"type": "object", "minProperties": 5}, "comparisonPerformed": {"const": true}, "recommendationStrength": {"const": "not_available"}, "decisionScope": {"const": "one_run"}, "deploymentModelAdopted": {"const": false}, "operatorType": {"const": "trusted_internal_unverified"}, "institutionalApproval": {"const": false}, "uncertaintyStatus": {"const": "pending_selected_model_calibration"}, "preparednessStatus": {"const": "unavailable_missing_planning_policy"}, "inputHashes": {"type": "object", "minProperties": 4}, "artifactHashes": {"type": "object", "minProperties": 6}, "commitReadiness": {"const": "ready_for_runtime_commit"}, "intendedUse": {"type": "string", "minLength": 1}, "limitations": {"type": "array", "minItems": 6, "items": {"type": "string"}}, "generatedAt": {"format": "date-time"}
      }
    },
    {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "runId", "jobId", "datasetId", "deploymentId", "workflowMode", "sourceType", "decision", "assessment", "authorization", "model", "features", "target", "horizonWeeks", "training", "comparisonPerformed", "recommendationStrength", "decisionScope", "deploymentModelAdopted", "operatorType", "institutionalApproval", "uncertaintyStatus", "preparednessStatus", "inputHashes", "artifactHashes", "commitReadiness", "intendedUse", "limitations", "generatedAt"],
      "properties": {
        "schemaVersion": {"const": "2.0"}, "runId": {"format": "uuid"}, "jobId": {"format": "uuid"}, "datasetId": {"$ref": "#/$defs/sha"}, "deploymentId": {"const": "dhaka_south"}, "workflowMode": {"const": "approved_assessment_forecast"}, "sourceType": {"const": "uploaded"}, "decision": {"$ref": "#/$defs/decision"}, "assessment": {"$ref": "#/$defs/assessment"}, "authorization": {"$ref": "#/$defs/authorization"}, "model": {"$ref": "#/$defs/modelEvidence"}, "features": {"$ref": "#/$defs/features"}, "target": {"const": "target_cases_next_2w"}, "horizonWeeks": {"const": 2}, "training": {"$ref": "#/$defs/training"}, "comparisonPerformed": {"const": true}, "recommendationStrength": {"const": "not_available"}, "decisionScope": {"const": "one_run"}, "deploymentModelAdopted": {"const": false}, "operatorType": {"const": "trusted_internal_unverified"}, "institutionalApproval": {"const": false}, "uncertaintyStatus": {"const": "pending_selected_model_calibration"}, "preparednessStatus": {"const": "unavailable_missing_planning_policy"}, "inputHashes": {"$ref": "#/$defs/inputHashes"}, "artifactHashes": {"type": "object", "minProperties": 7, "additionalProperties": {"$ref": "#/$defs/sha"}}, "commitReadiness": {"const": "ready_for_runtime_commit"}, "intendedUse": {"type": "string", "minLength": 1}, "limitations": {"type": "array", "minItems": 6, "items": {"type": "string"}}, "generatedAt": {"format": "date-time"}
      }
    }
  ],
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "period": {"type": "string", "pattern": "^[0-9]{4}-W[0-9]{2}$"}, "range": {"type": "object", "additionalProperties": false, "required": ["start", "end"], "properties": {"start": {"$ref": "#/$defs/period"}, "end": {"$ref": "#/$defs/period"}}},
    "policy": {"type": "object", "additionalProperties": false, "required": ["policyId", "policyVersion", "policySha256"], "properties": {"policyId": {"type": "string"}, "policyVersion": {"const": "p2-v1"}, "policySha256": {"$ref": "#/$defs/sha"}}},
    "decision": {"type": "object", "additionalProperties": false, "required": ["id", "commitSha256", "outcome", "operatorType", "policy"], "properties": {"id": {"format": "uuid"}, "commitSha256": {"$ref": "#/$defs/sha"}, "outcome": {"enum": ["approve_technical_winner", "keep_current_model"]}, "operatorType": {"const": "trusted_internal_unverified"}, "policy": {"$ref": "#/$defs/policy"}}},
    "assessment": {"type": "object", "additionalProperties": false, "required": ["id", "commitSha256", "policy", "labelledRows", "plannedFoldCount", "successfulFolds", "failedFolds", "foldPlanSha256", "selectedEvaluationPeriod", "recommendationStrength"], "properties": {"id": {"format": "uuid"}, "commitSha256": {"$ref": "#/$defs/sha"}, "policy": {"$ref": "#/$defs/policy"}, "labelledRows": {"type": "integer", "minimum": 157}, "plannedFoldCount": {"type": "integer", "minimum": 52, "maximum": 68}, "successfulFolds": {"type": "integer", "minimum": 52, "maximum": 68}, "failedFolds": {"const": 0}, "foldPlanSha256": {"$ref": "#/$defs/sha"}, "selectedEvaluationPeriod": {"$ref": "#/$defs/range"}, "recommendationStrength": {"const": "not_available"}}},
    "authorization": {"type": "object", "additionalProperties": false, "required": ["id", "commitSha256", "scope", "status"], "properties": {"id": {"format": "uuid"}, "commitSha256": {"$ref": "#/$defs/sha"}, "scope": {"const": "one_run"}, "status": {"const": "reserved"}}},
    "modelEvidence": {"type": "object", "additionalProperties": false, "required": ["id", "family", "parameterHash", "technicalWinnerId", "technicalWinnerParameterHash", "candidateRegistrySha256", "runtimeLibrary"], "properties": {"id": {"enum": ["ridge_regression", "poisson_regression", "random_forest", "gradient_boosting"]}, "family": {"type": "string", "minLength": 1}, "parameterHash": {"$ref": "#/$defs/sha"}, "technicalWinnerId": {"type": ["string", "null"]}, "technicalWinnerParameterHash": {"anyOf": [{"$ref": "#/$defs/sha"}, {"type": "null"}]}, "candidateRegistrySha256": {"$ref": "#/$defs/sha"}, "runtimeLibrary": {"const": "scikit-learn"}}},
    "features": {"type": "object", "additionalProperties": false, "required": ["count", "orderSha256", "matrixSha256"], "properties": {"count": {"const": 18}, "orderSha256": {"$ref": "#/$defs/sha"}, "matrixSha256": {"$ref": "#/$defs/sha"}}},
    "training": {"type": "object", "additionalProperties": false, "required": ["datasetId", "featureMatrixSha256", "trainingRowCount", "trainingPeriod", "featureOrderSha256", "library"], "properties": {"datasetId": {"$ref": "#/$defs/sha"}, "featureMatrixSha256": {"$ref": "#/$defs/sha"}, "trainingRowCount": {"type": "integer", "minimum": 157}, "trainingPeriod": {"$ref": "#/$defs/range"}, "featureOrderSha256": {"$ref": "#/$defs/sha"}, "library": {"const": "scikit-learn"}}},
    "inputHashes": {"type": "object", "additionalProperties": false, "required": ["canonicalDengue", "canonicalClimate", "assessmentCommit", "decisionCommit", "authorizationCommit"], "properties": {"canonicalDengue": {"$ref": "#/$defs/sha"}, "canonicalClimate": {"$ref": "#/$defs/sha"}, "assessmentCommit": {"$ref": "#/$defs/sha"}, "decisionCommit": {"$ref": "#/$defs/sha"}, "authorizationCommit": {"$ref": "#/$defs/sha"}}}
  }
}
