{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://dengueops.local/schemas/candidate_models.schema.json",
  "type":"object","additionalProperties":false,
  "required":["candidate_registry_schema_version","candidate_registry_version","feature_order_sha256","target","horizon_weeks","output_domain_policy","candidates"],
  "properties":{
    "candidate_registry_schema_version":{"const":"2.0"},"candidate_registry_version":{"const":"p2-v1"},
    "feature_order_sha256":{"const":"aeccbe517da452e1132f08c02599418523fb003280b11ff9cda66cfb3aa55a85"},
    "target":{"const":"target_cases_next_2w"},"horizon_weeks":{"const":2},
    "output_domain_policy":{"const":"preserve_raw_and_publish_maximum_of_zero_and_raw_prediction"},
    "candidates":{"type":"array","minItems":10,"maxItems":10,"items":{"$ref":"#/$defs/candidate"}}
  },
  "$defs":{
    "sha":{"type":"string","pattern":"^[a-f0-9]{64}$"},"text":{"type":"string","minLength":1},
    "candidate":{"type":"object","additionalProperties":false,
      "required":["model_id","candidate_class","selection_role","model_family","estimator_library","estimator_library_version","parameters","parameters_sha256","preprocessing","preprocessing_identity","deterministic_controls","minimum_training_rows","target","horizon_weeks","feature_order_sha256","output_domain_rule","failure_policy","uncertainty_capability","selectable","selection_complexity_rank","limitations"],
      "properties":{
        "model_id":{"enum":["moving_average_4w","seasonal_naive_52w","ridge_regression","poisson_regression","random_forest","gradient_boosting","elastic_net","negative_binomial_regression","extra_trees","hist_gradient_boosting"]},
        "candidate_class":{"enum":["learned_model","comparison_baseline"]},"selection_role":{"enum":["learned_selectable","baseline_only"]},
        "model_family":{"$ref":"#/$defs/text"},"estimator_library":{"$ref":"#/$defs/text"},"estimator_library_version":{"$ref":"#/$defs/text"},
        "parameters":{"type":"object","additionalProperties":{"type":["string","number","integer","boolean","null"]}},"parameters_sha256":{"$ref":"#/$defs/sha"},
        "preprocessing":{"type":"object","additionalProperties":false,"required":["type","fit_scope"],"properties":{"type":{"enum":["none","StandardScaler"]},"fit_scope":{"enum":["not_applicable","fold_training_rows_only"]}}},
        "preprocessing_identity":{"$ref":"#/$defs/sha"},
        "deterministic_controls":{"type":"object","additionalProperties":false,"required":["runtime_hyperparameter_search","browser_parameters_allowed","random_seed"],"properties":{"runtime_hyperparameter_search":{"const":false},"browser_parameters_allowed":{"const":false},"random_seed":{"type":["integer","null"]}}},
        "minimum_training_rows":{"type":"integer","minimum":0},"target":{"const":"target_cases_next_2w"},"horizon_weeks":{"const":2},"feature_order_sha256":{"const":"aeccbe517da452e1132f08c02599418523fb003280b11ff9cda66cfb3aa55a85"},
        "output_domain_rule":{"$ref":"#/$defs/text"},"failure_policy":{"const":"failed_fold_excludes_candidate_without_changing_common_plan"},
        "uncertainty_capability":{"enum":["point_forecast_only","model_specific_calibration_pending"]},"selectable":{"type":"boolean"},
        "selection_complexity_rank":{"type":"integer","minimum":1},"limitations":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/text"}}
      },
      "allOf":[
        {"if":{"properties":{"candidate_class":{"const":"comparison_baseline"}}},"then":{"properties":{"selection_role":{"const":"baseline_only"},"selectable":{"const":false}}}},
        {"if":{"properties":{"candidate_class":{"const":"learned_model"}}},"then":{"properties":{"selection_role":{"const":"learned_selectable"},"selectable":{"const":true}}}}
      ]
    }
  }
}
