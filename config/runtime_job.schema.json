{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dengueops.ai/schemas/runtime_job.schema.json",
  "additionalProperties": false,
  "properties": {
    "jobKind": {},
    "schemaVersion": {},
    "jobId": {},
    "runId": {},
    "outcomeId": {},
    "forecastRunId": {},
    "expectedForecastCommitSha256": {},
    "observationPayloadSha256": {},
    "observation": {},
    "operatorIdentifier": {},
    "assessmentId": {},
    "decisionId": {},
    "decisionCommitSha256": {},
    "authorizationId": {},
    "assessmentCommitSha256": {},
    "selectedModelId": {},
    "selectedModelParameterSha256": {},
    "workspaceId": {},
    "datasetId": {},
    "deploymentId": {},
    "workflowMode": {},
    "validationRecordSha256": {},
    "policyId": {},
    "policyVersion": {},
    "policySha256": {},
    "assessmentPolicyId": {},
    "assessmentPolicyVersion": {},
    "assessmentPolicySha256": {},
    "candidateRegistrySha256": {},
    "status": {},
    "progress": {},
    "createdAt": {},
    "claimedAt": {},
    "startedAt": {},
    "updatedAt": {},
    "completedAt": {},
    "heartbeatAt": {},
    "workerId": {},
    "processId": {},
    "timeoutSeconds": {},
    "retryCount": {},
    "error": {},
    "committedRunId": {},
    "committedAssessmentId": {},
    "committedOutcomeId": {}
  },
  "oneOf": [
    { "$ref": "#/$defs/quick" },
    { "$ref": "#/$defs/assessment" },
    { "$ref": "#/$defs/approved" },
    { "$ref": "#/$defs/outcome" }
  ],
  "$defs": {
    "uuid": { "type": "string", "format": "uuid" },
    "sha": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "status": {
      "enum": [
        "queued",
        "running",
        "committing",
        "completed",
        "failed",
        "timed_out",
        "cancelled"
      ]
    },
    "error": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "retryable": { "type": "boolean" }
      }
    },
    "common": {
      "type": "object",
      "properties": {
        "schemaVersion": { "const": "1.0" },
        "jobId": { "$ref": "#/$defs/uuid" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "datasetId": { "$ref": "#/$defs/sha" },
        "deploymentId": { "const": "dhaka_south" },
        "validationRecordSha256": { "$ref": "#/$defs/sha" },
        "status": { "$ref": "#/$defs/status" },
        "progress": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "claimedAt": { "type": ["string", "null"], "format": "date-time" },
        "startedAt": { "type": ["string", "null"], "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": ["string", "null"], "format": "date-time" },
        "heartbeatAt": { "type": ["string", "null"], "format": "date-time" },
        "workerId": { "type": ["string", "null"] },
        "processId": { "type": ["integer", "null"] },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "retryCount": { "type": "integer", "minimum": 0 },
        "error": { "$ref": "#/$defs/error" }
      }
    },
    "quick": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "jobId",
        "runId",
        "workspaceId",
        "datasetId",
        "deploymentId",
        "workflowMode",
        "validationRecordSha256",
        "policyId",
        "policyVersion",
        "policySha256",
        "status",
        "progress",
        "createdAt",
        "claimedAt",
        "startedAt",
        "updatedAt",
        "completedAt",
        "heartbeatAt",
        "workerId",
        "processId",
        "timeoutSeconds",
        "retryCount",
        "error",
        "committedRunId"
      ],
      "properties": {
        "jobKind": { "const": "quick_forecast" },
        "schemaVersion": { "const": "1.0" },
        "jobId": { "$ref": "#/$defs/uuid" },
        "runId": { "$ref": "#/$defs/uuid" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "datasetId": { "$ref": "#/$defs/sha" },
        "deploymentId": { "const": "dhaka_south" },
        "workflowMode": { "const": "quick_forecast" },
        "validationRecordSha256": { "$ref": "#/$defs/sha" },
        "policyId": { "const": "RUNTIME.QUICK_FORECAST.COMPATIBILITY" },
        "policyVersion": { "const": "p1.4f-v1" },
        "policySha256": { "$ref": "#/$defs/sha" },
        "status": { "$ref": "#/$defs/status" },
        "progress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "claimedAt": { "type": ["string", "null"], "format": "date-time" },
        "startedAt": { "type": ["string", "null"], "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": ["string", "null"], "format": "date-time" },
        "heartbeatAt": { "type": ["string", "null"], "format": "date-time" },
        "workerId": { "type": ["string", "null"] },
        "processId": { "type": ["integer", "null"] },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "retryCount": { "type": "integer", "minimum": 0 },
        "error": { "$ref": "#/$defs/error" },
        "committedRunId": { "type": ["string", "null"], "format": "uuid" }
      }
    },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "jobKind",
        "jobId",
        "assessmentId",
        "workspaceId",
        "datasetId",
        "deploymentId",
        "workflowMode",
        "validationRecordSha256",
        "assessmentPolicyId",
        "assessmentPolicyVersion",
        "assessmentPolicySha256",
        "candidateRegistrySha256",
        "status",
        "progress",
        "createdAt",
        "claimedAt",
        "startedAt",
        "updatedAt",
        "completedAt",
        "heartbeatAt",
        "workerId",
        "processId",
        "timeoutSeconds",
        "retryCount",
        "error",
        "committedAssessmentId"
      ],
      "properties": {
        "schemaVersion": { "const": "1.0" },
        "jobKind": { "const": "dataset_assessment" },
        "jobId": { "$ref": "#/$defs/uuid" },
        "assessmentId": { "$ref": "#/$defs/uuid" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "datasetId": { "$ref": "#/$defs/sha" },
        "deploymentId": { "const": "dhaka_south" },
        "workflowMode": { "const": "assess_dataset" },
        "validationRecordSha256": { "$ref": "#/$defs/sha" },
        "assessmentPolicyId": {
          "const": "RUNTIME.DATASET_ASSESSMENT.GOVERNANCE"
        },
        "assessmentPolicyVersion": { "const": "p1.4d-1-v1" },
        "assessmentPolicySha256": { "$ref": "#/$defs/sha" },
        "candidateRegistrySha256": { "$ref": "#/$defs/sha" },
        "status": { "$ref": "#/$defs/status" },
        "progress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "claimedAt": { "type": ["string", "null"], "format": "date-time" },
        "startedAt": { "type": ["string", "null"], "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": ["string", "null"], "format": "date-time" },
        "heartbeatAt": { "type": ["string", "null"] },
        "workerId": { "type": ["string", "null"] },
        "processId": { "type": ["integer", "null"] },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "retryCount": { "type": "integer", "minimum": 0 },
        "error": { "$ref": "#/$defs/error" },
        "committedAssessmentId": {
          "type": ["string", "null"],
          "format": "uuid"
        }
      }
    },
    "approved": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "jobKind",
        "jobId",
        "runId",
        "decisionId",
        "decisionCommitSha256",
        "authorizationId",
        "assessmentId",
        "assessmentCommitSha256",
        "workspaceId",
        "datasetId",
        "deploymentId",
        "selectedModelId",
        "selectedModelParameterSha256",
        "workflowMode",
        "validationRecordSha256",
        "status",
        "progress",
        "createdAt",
        "claimedAt",
        "startedAt",
        "updatedAt",
        "completedAt",
        "heartbeatAt",
        "workerId",
        "processId",
        "timeoutSeconds",
        "retryCount",
        "error",
        "committedRunId"
      ],
      "properties": {
        "schemaVersion": { "const": "1.0" },
        "jobKind": { "const": "approved_forecast" },
        "jobId": { "$ref": "#/$defs/uuid" },
        "runId": { "$ref": "#/$defs/uuid" },
        "decisionId": { "$ref": "#/$defs/uuid" },
        "decisionCommitSha256": { "$ref": "#/$defs/sha" },
        "authorizationId": { "$ref": "#/$defs/uuid" },
        "assessmentId": { "$ref": "#/$defs/uuid" },
        "assessmentCommitSha256": { "$ref": "#/$defs/sha" },
        "workspaceId": { "$ref": "#/$defs/uuid" },
        "datasetId": { "$ref": "#/$defs/sha" },
        "deploymentId": { "const": "dhaka_south" },
        "selectedModelId": {
          "enum": [
            "ridge_regression",
            "poisson_regression",
            "random_forest",
            "gradient_boosting"
          ]
        },
        "selectedModelParameterSha256": { "$ref": "#/$defs/sha" },
        "workflowMode": { "const": "approved_assessment_forecast" },
        "validationRecordSha256": { "$ref": "#/$defs/sha" },
        "status": { "$ref": "#/$defs/status" },
        "progress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "claimedAt": { "type": ["string", "null"] },
        "startedAt": { "type": ["string", "null"] },
        "updatedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": ["string", "null"] },
        "heartbeatAt": { "type": ["string", "null"] },
        "workerId": { "type": ["string", "null"] },
        "processId": { "type": ["integer", "null"] },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "retryCount": { "type": "integer", "minimum": 0 },
        "error": { "$ref": "#/$defs/error" },
        "committedRunId": { "type": ["string", "null"], "format": "uuid" }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "jobKind",
        "jobId",
        "outcomeId",
        "forecastRunId",
        "expectedForecastCommitSha256",
        "observationPayloadSha256",
        "observation",
        "operatorIdentifier",
        "deploymentId",
        "workflowMode",
        "policyId",
        "policyVersion",
        "policySha256",
        "status",
        "progress",
        "createdAt",
        "claimedAt",
        "startedAt",
        "updatedAt",
        "completedAt",
        "heartbeatAt",
        "workerId",
        "processId",
        "timeoutSeconds",
        "retryCount",
        "error",
        "committedOutcomeId"
      ],
      "properties": {
        "schemaVersion": { "const": "1.0" },
        "jobKind": { "const": "forecast_outcome" },
        "jobId": { "$ref": "#/$defs/uuid" },
        "outcomeId": { "$ref": "#/$defs/uuid" },
        "forecastRunId": { "$ref": "#/$defs/uuid" },
        "expectedForecastCommitSha256": { "$ref": "#/$defs/sha" },
        "observationPayloadSha256": { "$ref": "#/$defs/sha" },
        "observation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "deploymentId",
            "geography",
            "targetColumn",
            "forecastHorizonWeeks",
            "forecastTargetPeriod",
            "observedRaw",
            "observationSourceType",
            "observationSourceId",
            "observationRecordId",
            "observationRecordedAt",
            "limitationsAcknowledged"
          ],
          "properties": {
            "deploymentId": { "const": "dhaka_south" },
            "geography": {
              "const": {
                "level": "city",
                "id": "BGD-DHAKA-SOUTH",
                "name": "Dhaka South"
              }
            },
            "targetColumn": { "const": "target_cases_next_2w" },
            "forecastHorizonWeeks": { "const": 2 },
            "forecastTargetPeriod": {
              "type": "string",
              "pattern": "^[0-9]{4}-W[0-9]{2}$"
            },
            "observedRaw": { "type": "integer", "minimum": 0 },
            "observationSourceType": { "const": "synthetic_benchmark" },
            "observationSourceId": {
              "const": "dhaka_south_synthetic_benchmark"
            },
            "observationRecordId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
            },
            "observationRecordedAt": {
              "type": "string",
              "format": "date-time",
              "pattern": "Z$"
            },
            "limitationsAcknowledged": { "const": true }
          }
        },
        "operatorIdentifier": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "deploymentId": { "const": "dhaka_south" },
        "workflowMode": { "const": "forecast_outcome_monitoring" },
        "policyId": { "const": "RUNTIME.FORECAST_OUTCOME.MONITORING" },
        "policyVersion": { "const": "p1.4g-v1" },
        "policySha256": { "$ref": "#/$defs/sha" },
        "status": { "$ref": "#/$defs/status" },
        "progress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "claimedAt": { "type": ["string", "null"] },
        "startedAt": { "type": ["string", "null"] },
        "updatedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": ["string", "null"] },
        "heartbeatAt": { "type": ["string", "null"] },
        "workerId": { "type": ["string", "null"] },
        "processId": { "type": ["integer", "null"] },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "retryCount": { "type": "integer", "minimum": 0 },
        "error": { "$ref": "#/$defs/error" },
        "committedOutcomeId": { "type": ["string", "null"], "format": "uuid" }
      }
    }
  }
}
