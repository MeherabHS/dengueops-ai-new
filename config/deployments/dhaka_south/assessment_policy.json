    "intended_use":  [
                         "Govern dataset-flexible temporal comparison for processed, synthetic-benchmark-compatible Dhaka South uploads with 52 to 68 common out-of-sample folds."
                     ],
    "limitations":  [
                        "The policy does not clean raw data, fabricate observations, interpolate targets, or correct unknown source defects.",
                        "Recommendation-strength thresholds are not governed, so the technical winner remains evidence only.",
                        "Phase 2 p2-v2 assessments remain separate from one-run forecast decisions and persistent lifecycle assignment.",
                        "The most recent 68 folds are selected when more than 68 are available, while older rows remain in expanding training.",
                        "The source scope remains synthetic-benchmark compatible and does not establish real-world Dhaka validity."
                    ],
    "prohibited_claims":  [
                              "The technical winner is automatically the deployment model.",
                              "A Phase 2 assessment authorizes a one-run forecast.",
                              "Assessment evidence is epidemiologically validated or institutionally approved.",
                              "Assessment changes preparedness, facility, alert, directive, or model-promotion behavior.",
                              "Recommendation strength is available without governed thresholds."
                          ],
