{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "runId", "jobId", "datasetId", "deploymentId", "sourceType", "workflowMode", "decisionId", "assessmentId", "authorizationId", "selectedModelId", "selectedModelParameterSha256", "technicalWinnerModelId", "decisionOutcome", "selectionBasis", "comparisonPerformed", "recommendationStrength", "decisionScope", "deploymentModelAdopted", "trainingDataIdentity", "latestObservedCases", "forecastRaw", "forecastReported", "targetPeriod", "target", "horizonWeeks", "forecastGrowthCategory", "reportingRoundingPolicy", "clippingApplied", "generatedAt", "uncertaintyStatus", "preparednessStatus"],
      "properties": {
        "schemaVersion": {"const": "1.0"}, "runId": {"format": "uuid"}, "jobId": {"format": "uuid"}, "datasetId": {"$ref": "#/$defs/sha"}, "deploymentId": {"const": "dhaka_south"}, "sourceType": {"const": "uploaded"}, "workflowMode": {"const": "approved_assessment_forecast"}, "decisionId": {"format": "uuid"}, "assessmentId": {"format": "uuid"}, "authorizationId": {"format": "uuid"}, "selectedModelId": {"$ref": "#/$defs/model"}, "selectedModelParameterSha256": {"$ref": "#/$defs/sha"}, "technicalWinnerModelId": {"type": ["string", "null"]}, "decisionOutcome": {"enum": ["approve_technical_winner", "keep_current_model"]}, "selectionBasis": {"const": "immutable_dataset_assessment_and_internal_one_run_decision"}, "comparisonPerformed": {"const": true}, "recommendationStrength": {"const": "not_available"}, "decisionScope": {"const": "one_run"}, "deploymentModelAdopted": {"const": false}, "trainingDataIdentity": {"type": "object", "minProperties": 5}, "latestObservedCases": {"type": "integer", "minimum": 0}, "forecastRaw": {"type": "number"}, "forecastReported": {"type": "integer", "minimum": 0}, "targetPeriod": {"type": "string"}, "target": {"const": "target_cases_next_2w"}, "horizonWeeks": {"const": 2}, "forecastGrowthCategory": {"enum": ["Increasing", "Stable", "Decreasing"]}, "reportingRoundingPolicy": {"const": "nearest_integer_python_round_half_to_even"}, "clippingApplied": {"type": "boolean"}, "generatedAt": {"format": "date-time"}, "uncertaintyStatus": {"const": "pending_selected_model_calibration"}, "preparednessStatus": {"const": "unavailable_missing_planning_policy"}
      }
    },
    {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "runId", "jobId", "datasetId", "deploymentId", "sourceType", "workflowMode", "decisionId", "assessmentId", "authorizationId", "selectedModelId", "selectedModelParameterSha256", "technicalWinnerModelId", "technicalWinnerParameterSha256", "decisionOutcome", "selectionBasis", "comparisonPerformed", "recommendationStrength", "decisionScope", "deploymentModelAdopted", "governanceEvidence", "trainingDataIdentity", "latestObservedCases", "forecastRaw", "forecastReported", "targetPeriod", "target", "horizonWeeks", "forecastGrowthCategory", "reportingRoundingPolicy", "clippingApplied", "generatedAt", "uncertaintyStatus", "preparednessStatus"],
      "properties": {
        "schemaVersion": {"const": "2.0"}, "runId": {"format": "uuid"}, "jobId": {"format": "uuid"}, "datasetId": {"$ref": "#/$defs/sha"}, "deploymentId": {"const": "dhaka_south"}, "sourceType": {"const": "uploaded"}, "workflowMode": {"const": "approved_assessment_forecast"}, "decisionId": {"format": "uuid"}, "assessmentId": {"format": "uuid"}, "authorizationId": {"format": "uuid"}, "selectedModelId": {"$ref": "#/$defs/model"}, "selectedModelParameterSha256": {"$ref": "#/$defs/sha"}, "technicalWinnerModelId": {"type": ["string", "null"]}, "technicalWinnerParameterSha256": {"anyOf": [{"$ref": "#/$defs/sha"}, {"type": "null"}]}, "decisionOutcome": {"enum": ["approve_technical_winner", "keep_current_model"]}, "selectionBasis": {"const": "immutable_dataset_assessment_and_internal_one_run_decision"}, "comparisonPerformed": {"const": true}, "recommendationStrength": {"const": "not_available"}, "decisionScope": {"const": "one_run"}, "deploymentModelAdopted": {"const": false}, "governanceEvidence": {"$ref": "#/$defs/governance"}, "trainingDataIdentity": {"$ref": "#/$defs/training"}, "latestObservedCases": {"type": "integer", "minimum": 0}, "forecastRaw": {"type": "number"}, "forecastReported": {"type": "integer", "minimum": 0}, "targetPeriod": {"$ref": "#/$defs/period"}, "target": {"const": "target_cases_next_2w"}, "horizonWeeks": {"const": 2}, "forecastGrowthCategory": {"enum": ["Increasing", "Stable", "Decreasing"]}, "reportingRoundingPolicy": {"const": "nearest_integer_python_round_half_to_even"}, "clippingApplied": {"type": "boolean"}, "generatedAt": {"format": "date-time"}, "uncertaintyStatus": {"const": "pending_selected_model_calibration"}, "preparednessStatus": {"const": "unavailable_missing_planning_policy"}
      }
    }
  ],
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "model": {"enum": ["ridge_regression", "poisson_regression", "random_forest", "gradient_boosting"]}, "period": {"type": "string", "pattern": "^[0-9]{4}-W[0-9]{2}$"},
    "range": {"type": "object", "additionalProperties": false, "required": ["start", "end"], "properties": {"start": {"$ref": "#/$defs/period"}, "end": {"$ref": "#/$defs/period"}}},
    "policy": {"type": "object", "additionalProperties": false, "required": ["policyId", "policyVersion", "policySha256"], "properties": {"policyId": {"type": "string", "minLength": 1}, "policyVersion": {"const": "p2-v1"}, "policySha256": {"$ref": "#/$defs/sha"}}},
    "governance": {"type": "object", "additionalProperties": false, "required": ["assessmentCommitSha256", "decisionCommitSha256", "authorizationCommitSha256", "assessmentPolicy", "decisionPolicy", "candidateRegistrySha256", "assessmentLabelledRows", "assessmentPlannedFoldCount", "successfulFolds", "failedFolds", "selectedEvaluationPeriod", "foldPlanSha256"], "properties": {"assessmentCommitSha256": {"$ref": "#/$defs/sha"}, "decisionCommitSha256": {"$ref": "#/$defs/sha"}, "authorizationCommitSha256": {"$ref": "#/$defs/sha"}, "assessmentPolicy": {"$ref": "#/$defs/policy"}, "decisionPolicy": {"$ref": "#/$defs/policy"}, "candidateRegistrySha256": {"$ref": "#/$defs/sha"}, "assessmentLabelledRows": {"type": "integer", "minimum": 157}, "assessmentPlannedFoldCount": {"type": "integer", "minimum": 52, "maximum": 68}, "successfulFolds": {"type": "integer", "minimum": 52, "maximum": 68}, "failedFolds": {"const": 0}, "selectedEvaluationPeriod": {"$ref": "#/$defs/range"}, "foldPlanSha256": {"$ref": "#/$defs/sha"}}},
    "training": {"type": "object", "additionalProperties": false, "required": ["datasetId", "featureMatrixSha256", "trainingRowCount", "trainingPeriod", "featureOrderSha256", "library"], "properties": {"datasetId": {"$ref": "#/$defs/sha"}, "featureMatrixSha256": {"$ref": "#/$defs/sha"}, "trainingRowCount": {"type": "integer", "minimum": 157}, "trainingPeriod": {"$ref": "#/$defs/range"}, "featureOrderSha256": {"$ref": "#/$defs/sha"}, "library": {"const": "scikit-learn"}}}
  }
}
