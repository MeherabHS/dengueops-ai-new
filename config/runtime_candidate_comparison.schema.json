  "$defs": {
    "p1": {
      "uuid": {
        "type": "string",
        "format": "uuid"
      },
      "sha": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      },
      "model": {
        "enum": [
          "previous_week_naive",
          "moving_average_4w",
          "seasonal_naive_52w",
          "ridge_regression",
          "poisson_regression",
          "random_forest",
          "gradient_boosting"
        ]
      },
      "setStatus": {
        "enum": [
          "complete_candidate_set",
          "partial_candidate_set",
          "insufficient_candidate_breadth"
        ]
      },
      "metrics": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mae",
          "rmse",
          "wape",
          "medianAbsoluteError",
          "maximumAbsoluteError",
          "clippingCount",
          "warningCount",
          "runtimeSeconds"
        ],
