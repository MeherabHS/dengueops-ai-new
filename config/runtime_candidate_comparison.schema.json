          "mae": {
            "type": "number",
            "minimum": 0
          },
          "rmse": {
            "type": "number",
            "minimum": 0
          },
          "wape": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "medianAbsoluteError": {
            "type": "number",
            "minimum": 0
          },
          "maximumAbsoluteError": {
            "type": "number",
            "minimum": 0
          },
          "clippingCount": {
            "type": "integer",
            "minimum": 0
          },
          "warningCount": {
            "type": "integer",
            "minimum": 0
          },
          "runtimeSeconds": {
            "type": "number",
            "minimum": 0
          }
        }
      },
      "candidate": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "modelId",
          "modelLabel",
          "candidateClass",
          "deployabilityClass",
          "parametersSha256",
          "eligible",
          "completionStatus",
          "reasonCodes",
          "reasons",
          "successfulFolds",
          "failedFolds",
          "selectionEligible",
          "selectionComplexityRank",
          "metrics",
          "executionMode",
          "historicalPredictionsReused",
          "foldWinsTiesLosses"
        ],
        "properties": {
          "modelId": {
            "$ref": "#/$defs/p1/model"
          },
          "modelLabel": {
            "type": "string",
            "minLength": 1
          },
          "candidateClass": {
            "enum": [
              "naive_baseline",
              "learned_model"
            ]
          },
          "deployabilityClass": {
            "enum": [
              "baseline_not_runtime_deployable",
              "deployable_learned_model"
