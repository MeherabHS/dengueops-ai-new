          "reasonCodes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "reasons": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "successfulFolds": {
            "type": "integer",
            "minimum": 0,
            "maximum": 68
          },
          "failedFolds": {
            "type": "integer",
            "minimum": 0,
            "maximum": 68
          },
          "selectionEligible": {
            "type": "boolean"
          },
          "selectionComplexityRank": {
            "type": "integer",
            "minimum": 1,
            "maximum": 7
