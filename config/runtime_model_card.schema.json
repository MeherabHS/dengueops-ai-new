    "calibration":{"$ref":"#/$defs/calibration"},"preparednessStatus":{"const":"unavailable_missing_planning_policy"},"inputHashes":{"type":"object","minProperties":4},"artifactHashes":{"type":"object","minProperties":8,"additionalProperties":{"$ref":"#/$defs/sha"}},
