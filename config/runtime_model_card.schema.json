{
  "$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","additionalProperties":false,
  "required":["schemaVersion","runId","jobId","datasetId","deploymentId","workflowMode","sourceType","model","features","target","horizonWeeks","training","policy","comparisonPerformed","bestModelClaim","uncertaintyStatus","calibration","preparednessStatus","inputHashes","artifactHashes","commitReadiness","intendedUse","limitations","generatedAt"],
