{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    { "$ref": "#/$defs/phase1" },
    { "$ref": "#/$defs/phase2" }
  ],
  "$defs": {
    "sha": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "model": { "enum": ["ridge_regression", "poisson_regression", "random_forest", "gradient_boosting"] },
    "phase1": {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "authorizationId", "decisionId", "decisionCommitSha256", "assessmentId", "assessmentCommitSha256", "datasetId", "deploymentId", "selectedModelId", "selectedModelParameterSha256", "workflowMode", "scope", "initialStatus", "createdAt", "expiresAt", "policyId", "policyVersion", "policySha256"],
      "properties": { "schemaVersion": { "const": "1.0" }, "authorizationId": { "format": "uuid" }, "decisionId": { "format": "uuid" }, "decisionCommitSha256": { "$ref": "#/$defs/sha" }, "assessmentId": { "format": "uuid" }, "assessmentCommitSha256": { "$ref": "#/$defs/sha" }, "datasetId": { "$ref": "#/$defs/sha" }, "deploymentId": { "const": "dhaka_south" }, "selectedModelId": { "$ref": "#/$defs/model" }, "selectedModelParameterSha256": { "$ref": "#/$defs/sha" }, "workflowMode": { "const": "approved_assessment_forecast" }, "scope": { "const": "one_run" }, "initialStatus": { "const": "available" }, "createdAt": { "format": "date-time" }, "expiresAt": { "format": "date-time" }, "policyId": { "const": "RUNTIME.INTERNAL_ONE_RUN_MODEL_DECISION" }, "policyVersion": { "const": "p1.4d-3-e-v1" }, "policySha256": { "$ref": "#/$defs/sha" } }
    },
    "phase2": {
      "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "authorizationId", "decisionId", "decisionCommitSha256", "assessmentId", "assessmentCommitSha256", "assessmentPolicyId", "assessmentPolicyVersion", "assessmentPolicySha256", "decisionPolicyId", "decisionPolicyVersion", "decisionPolicySha256", "datasetId", "deploymentId", "selectedModelId", "selectedModelParameterSha256", "assessmentLabelledRows", "assessmentPlannedFoldCount", "foldPlanSha256", "workflowMode", "scope", "initialStatus", "createdAt", "expiresAt", "policyId", "policyVersion", "policySha256"],
      "properties": { "schemaVersion": { "const": "2.0" }, "authorizationId": { "format": "uuid" }, "decisionId": { "format": "uuid" }, "decisionCommitSha256": { "$ref": "#/$defs/sha" }, "assessmentId": { "format": "uuid" }, "assessmentCommitSha256": { "$ref": "#/$defs/sha" }, "assessmentPolicyId": { "const": "RUNTIME.DATASET_ASSESSMENT.GOVERNANCE" }, "assessmentPolicyVersion": { "const": "p2-v1" }, "assessmentPolicySha256": { "$ref": "#/$defs/sha" }, "decisionPolicyId": { "const": "RUNTIME.INTERNAL_ONE_RUN_MODEL_DECISION" }, "decisionPolicyVersion": { "const": "p2-v1" }, "decisionPolicySha256": { "$ref": "#/$defs/sha" }, "datasetId": { "$ref": "#/$defs/sha" }, "deploymentId": { "const": "dhaka_south" }, "selectedModelId": { "$ref": "#/$defs/model" }, "selectedModelParameterSha256": { "$ref": "#/$defs/sha" }, "assessmentLabelledRows": { "type": "integer", "minimum": 157 }, "assessmentPlannedFoldCount": { "type": "integer", "minimum": 52, "maximum": 68 }, "foldPlanSha256": { "$ref": "#/$defs/sha" }, "workflowMode": { "const": "approved_assessment_forecast" }, "scope": { "const": "one_run" }, "initialStatus": { "const": "available" }, "createdAt": { "format": "date-time" }, "expiresAt": { "format": "date-time" }, "policyId": { "const": "RUNTIME.INTERNAL_ONE_RUN_MODEL_DECISION" }, "policyVersion": { "const": "p2-v1" }, "policySha256": { "$ref": "#/$defs/sha" } }
    }
  }
}
