{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dengueops.local/schemas/model_explainability.schema.json",
  "title": "DengueOps Run-Specific Model Explainability",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "explainability_schema_version", "explainability_version", "availability_status",
    "model_id", "model_version", "estimator_family", "estimator_library",
    "estimator_library_version", "estimator_role", "model_parameters",
    "model_parameters_sha256", "target", "forecast_horizon", "feature_names",
    "feature_formula_ids", "feature_order_sha256", "training_period", "validation_period",
    "validation_rows", "validation_matrix_sha256", "evaluation_split", "importance_methods",
    "impurity_importance", "permutation_importance", "permutation_std",
    "permutation_repeats", "permutation_scoring", "permutation_random_state",
    "permutation_max_samples", "feature_ranking", "ranking_policy",
    "negative_importance_policy", "correlated_feature_warning",
    "causal_interpretation_allowed", "stability_status", "deployment_gate", "data_mode",
    "observed_data_mode", "limitations", "formula_registry_version",
    "formula_registry_sha256", "deployment_profile_id", "deployment_profile_sha256",
    "evidence_registry_sha256", "model_card_id", "model_card_version", "evidence_status",
    "compatibility_status", "active_model_evidence", "provenance",
    "generated_at"
  ],
  "properties": {
    "explainability_schema_version": {"const": "1.0"},
    "explainability_version": {"const": "p0.4-v1"},
    "availability_status": {"const": "generated"},
    "model_id": {"$ref": "#/$defs/nonEmpty"},
    "model_version": {"$ref": "#/$defs/nonEmpty"},
    "estimator_family": {"const": "GradientBoostingRegressor"},
    "estimator_library": {"const": "scikit-learn"},
    "estimator_library_version": {"$ref": "#/$defs/nonEmpty"},
    "estimator_role": {"const": "chronological_holdout_validation_model"},
    "model_parameters": {"type": "object", "minProperties": 1},
    "model_parameters_sha256": {"$ref": "#/$defs/sha256"},
    "target": {"const": "target_cases_next_2w"},
    "forecast_horizon": {"type": "object", "additionalProperties": false, "required": ["value", "unit"], "properties": {"value": {"const": 14}, "unit": {"const": "days"}}},
    "feature_names": {"$ref": "#/$defs/featureNames"},
    "feature_formula_ids": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "minItems": 1, "uniqueItems": true},
    "feature_order_sha256": {"$ref": "#/$defs/sha256"},
    "training_period": {"$ref": "#/$defs/periodRange"},
    "validation_period": {"$ref": "#/$defs/periodRange"},
    "validation_rows": {"type": "integer", "minimum": 1},
    "validation_matrix_sha256": {"$ref": "#/$defs/sha256"},
    "evaluation_split": {"const": "final_chronological_20_percent"},
    "importance_methods": {"type": "array", "const": ["holdout_permutation_importance", "native_tree_importance"]},
    "impurity_importance": {"$ref": "#/$defs/importanceArray"},
    "permutation_importance": {"$ref": "#/$defs/importanceArray"},
    "permutation_std": {"$ref": "#/$defs/nonnegativeArray"},
    "permutation_repeats": {"const": 20},
    "permutation_scoring": {"const": "neg_mean_absolute_error"},
    "permutation_random_state": {"const": 42},
    "permutation_max_samples": {"const": 1.0},
    "feature_ranking": {"type": "array", "minItems": 18, "maxItems": 18, "items": {"$ref": "#/$defs/ranking"}},
    "ranking_policy": {"type": "object", "additionalProperties": false, "required": ["primary", "secondary", "tie_breaker", "rank_disagreement_threshold"], "properties": {"primary": {"const": "permutation_mean_descending"}, "secondary": {"const": "impurity_importance_descending"}, "tie_breaker": {"const": "canonical_feature_index"}, "rank_disagreement_threshold": {"const": 5}}},
    "negative_importance_policy": {"$ref": "#/$defs/nonEmpty"},
    "correlated_feature_warning": {"$ref": "#/$defs/nonEmpty"},
    "causal_interpretation_allowed": {"const": false},
    "stability_status": {"const": "not_evaluated_across_temporal_folds"},
    "deployment_gate": {"const": "benchmark_only"},
    "data_mode": {"const": "synthetic_capability_demonstration"},
    "observed_data_mode": {"const": "synthetic"},
    "limitations": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "minItems": 1},
    "formula_registry_version": {"type": "string", "pattern": "^p[0-9]+\\.[0-9]+[a-z]?-v[0-9]+$"},
    "formula_registry_sha256": {"$ref": "#/$defs/sha256"},
    "deployment_profile_id": {"const": "dhaka_south"},
    "deployment_profile_sha256": {"$ref": "#/$defs/sha256"},
    "evidence_registry_sha256": {"$ref": "#/$defs/sha256"},
    "model_card_id": {"$ref": "#/$defs/nonEmpty"},
    "model_card_version": {"$ref": "#/$defs/nonEmpty"},
    "evidence_status": {"const": "historical"},
    "compatibility_status": {"const": "compatibility_only"},
    "active_model_evidence": {"const": false},
    "provenance": {"type": "object", "minProperties": 1},
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "period": {"type": "object", "additionalProperties": false, "required": ["epi_year", "epi_week"], "properties": {"epi_year": {"type": "integer"}, "epi_week": {"type": "integer", "minimum": 1, "maximum": 52}}},
    "periodRange": {"type": "object", "additionalProperties": false, "required": ["start", "end"], "properties": {"start": {"$ref": "#/$defs/period"}, "end": {"$ref": "#/$defs/period"}}},
    "featureNames": {"type": "array", "minItems": 18, "maxItems": 18, "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmpty"}},
    "importanceArray": {"type": "array", "minItems": 18, "maxItems": 18, "items": {"type": "number"}},
    "nonnegativeArray": {"type": "array", "minItems": 18, "maxItems": 18, "items": {"type": "number", "minimum": 0}},
    "ranking": {
      "type": "object", "additionalProperties": false,
      "required": ["feature_name", "formula_id", "feature_index", "impurity_importance", "permutation_mean", "permutation_standard_deviation", "rank_by_impurity", "rank_by_permutation", "rank_disagreement", "permutation_is_negative", "permutation_is_zero"],
      "properties": {
        "feature_name": {"$ref": "#/$defs/nonEmpty"}, "formula_id": {"$ref": "#/$defs/nonEmpty"},
        "feature_index": {"type": "integer", "minimum": 0, "maximum": 17},
        "impurity_importance": {"type": "number", "minimum": 0}, "permutation_mean": {"type": "number"},
        "permutation_standard_deviation": {"type": "number", "minimum": 0},
        "rank_by_impurity": {"type": "integer", "minimum": 1, "maximum": 18},
        "rank_by_permutation": {"type": "integer", "minimum": 1, "maximum": 18},
        "rank_disagreement": {"type": "boolean"}, "permutation_is_negative": {"type": "boolean"},
        "permutation_is_zero": {"type": "boolean"}
      }
    }
  }
}
