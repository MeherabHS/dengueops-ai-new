{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dengueops.local/schemas/forecast_uncertainty.schema.json",
  "title": "DengueOps Temporally Evaluated Forecast Uncertainty",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "uncertainty_schema_version", "uncertainty_artifact_version", "availability_status", "method_id", "method_version",
    "uncertainty_status", "active_model_id", "active_model_family", "active_model_library", "active_model_library_version",
    "active_model_parameters_sha256", "candidate_registry_sha256", "comparison_artifact_path", "comparison_artifact_sha256",
    "residual_source_artifact_path", "residual_source_artifact_sha256", "rolling_fold_reference_artifact_path",
    "rolling_fold_reference_artifact_sha256", "target", "horizon_weeks", "feature_order_sha256", "nominal_coverage",
    "calibration_design", "residual_summary", "historical_evaluation", "stratified_diagnostics", "future_forecast_interval",
    "retained_legacy_rmse", "operational_scenario_relationship", "is_prediction_interval", "calibrated_on_synthetic_data",
    "limitations", "deployment_id", "deployment_gate", "data_mode", "formula_registry_version", "formula_registry_sha256",
    "deployment_profile_sha256", "evidence_registry_sha256", "provenance", "generated_at"
  ],
  "properties": {
    "uncertainty_schema_version": {"const": "1.0"},
    "uncertainty_artifact_version": {"const": "p1.3-v1"},
    "availability_status": {"const": "generated"},
    "method_id": {"const": "prequential_expanding_absolute_residual_quantile"},
    "method_version": {"const": "p1.3-v1"},
    "uncertainty_status": {"const": "temporally_evaluated_synthetic_empirical_range"},
    "active_model_id": {"const": "random_forest"},
    "active_model_family": {"const": "RandomForestRegressor"},
    "active_model_library": {"const": "scikit-learn"},
    "active_model_library_version": {"$ref": "#/$defs/nonEmpty"},
    "active_model_parameters_sha256": {"$ref": "#/$defs/sha256"},
    "candidate_registry_sha256": {"$ref": "#/$defs/sha256"},
    "comparison_artifact_path": {"const": "data/candidate_model_comparison.json"},
    "comparison_artifact_sha256": {"$ref": "#/$defs/sha256"},
    "residual_source_artifact_path": {"const": "data/candidate_model_comparison.json"},
    "residual_source_artifact_sha256": {"$ref": "#/$defs/sha256"},
    "rolling_fold_reference_artifact_path": {"const": "data/rolling_validation.json"},
    "rolling_fold_reference_artifact_sha256": {"$ref": "#/$defs/sha256"},
    "target": {"const": "target_cases_next_2w"}, "horizon_weeks": {"const": 2},
    "feature_order_sha256": {"$ref": "#/$defs/sha256"}, "nominal_coverage": {"const": 0.9},
    "calibration_design": {"$ref": "#/$defs/calibrationDesign"},
    "residual_summary": {"type": "object", "additionalProperties": {"type": ["number", "integer"]}},
    "historical_evaluation": {"$ref": "#/$defs/historicalEvaluation"},
    "stratified_diagnostics": {"$ref": "#/$defs/stratifiedDiagnostics"},
    "future_forecast_interval": {"$ref": "#/$defs/futureInterval"},
    "retained_legacy_rmse": {"type": "object", "minProperties": 1},
    "operational_scenario_relationship": {"type": "object", "minProperties": 1},
    "is_prediction_interval": {"const": false}, "calibrated_on_synthetic_data": {"const": true},
    "limitations": {"type": "array", "minItems": 5, "items": {"$ref": "#/$defs/nonEmpty"}},
    "deployment_id": {"const": "dhaka_south"}, "deployment_gate": {"const": "benchmark_only"},
    "data_mode": {"const": "synthetic_capability_demonstration"},
    "formula_registry_version": {"const": "p1.3-v1"}, "formula_registry_sha256": {"$ref": "#/$defs/sha256"},
    "deployment_profile_sha256": {"$ref": "#/$defs/sha256"}, "evidence_registry_sha256": {"$ref": "#/$defs/sha256"},
    "provenance": {"type": "object", "minProperties": 1}, "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "calibrationDesign": {
      "type": "object", "additionalProperties": false,
      "required": ["design", "residual_definition", "calibration_score", "warmup_fold_count", "evaluation_fold_count",
        "final_residual_pool_count", "quantile_rank_rule", "alpha", "sorting", "interpolation", "ties", "coverage_rule",
        "lower_bound_policy", "rounding_policy"],
      "properties": {
        "design": {"const": "prequential_expanding_window_prior_residuals_only"},
        "residual_definition": {"const": "actual_minus_raw_prediction"}, "calibration_score": {"const": "absolute_residual"},
        "warmup_fold_count": {"const": 20}, "evaluation_fold_count": {"const": 48}, "final_residual_pool_count": {"const": 68},
        "quantile_rank_rule": {"const": "min(n, ceil((n + 1) * (1 - alpha)))"}, "alpha": {"const": 0.1},
        "sorting": {"const": "deterministic_ascending"}, "interpolation": {"const": "none"},
        "ties": {"const": "retained_as_separate_observations"}, "coverage_rule": {"const": "lower_raw <= actual <= upper_raw"},
        "lower_bound_policy": {"const": "clip_at_zero_after_raw_construction"},
        "rounding_policy": {"const": "raw_for_evaluation_outward_floor_lower_ceiling_upper_for_reporting"}
      }
    },
    "record": {
      "type": "object", "additionalProperties": false,
      "required": ["fold_id", "target_period", "actual", "raw_prediction", "prior_residual_count", "quantile_rank",
        "quantile_value", "lower_raw_unclipped", "lower_raw", "upper_raw", "lower_clipping_applied", "covered",
        "miss_direction", "miss_magnitude", "case_quartile", "trajectory_category"],
      "properties": {
        "fold_id": {"$ref": "#/$defs/nonEmpty"}, "target_period": {"$ref": "#/$defs/nonEmpty"},
        "actual": {"type": "number"}, "raw_prediction": {"type": "number"}, "prior_residual_count": {"type": "integer", "minimum": 20},
        "quantile_rank": {"type": "integer", "minimum": 1}, "quantile_value": {"type": "number", "minimum": 0},
        "lower_raw_unclipped": {"type": "number"}, "lower_raw": {"type": "number", "minimum": 0}, "upper_raw": {"type": "number"},
        "lower_clipping_applied": {"type": "boolean"}, "covered": {"type": "boolean"},
        "miss_direction": {"enum": ["lower", "upper", null]}, "miss_magnitude": {"type": "number", "minimum": 0},
        "case_quartile": {"type": "integer", "minimum": 1, "maximum": 4},
        "trajectory_category": {"enum": ["rising", "declining"]}
      }
    },
    "historicalEvaluation": {
      "type": "object", "additionalProperties": false, "required": ["records", "aggregate_metrics"],
      "properties": {"records": {"type": "array", "minItems": 48, "maxItems": 48, "items": {"$ref": "#/$defs/record"}},
        "aggregate_metrics": {"type": "object", "minProperties": 17}}
    },
    "stratifiedDiagnostics": {
      "type": "object", "additionalProperties": false, "required": ["actual_case_quartile", "trajectory"],
      "properties": {"actual_case_quartile": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"$ref": "#/$defs/stratum"}},
        "trajectory": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/stratum"}}}
    },
    "stratum": {
      "type": "object", "additionalProperties": false,
      "required": ["group", "count", "observed_coverage", "average_interval_width", "lower_miss_count", "upper_miss_count", "descriptive_only", "small_sample_warning"],
      "properties": {"group": {"type": ["string", "integer"]}, "count": {"type": "integer", "minimum": 1},
        "observed_coverage": {"type": "number", "minimum": 0, "maximum": 1}, "average_interval_width": {"type": "number", "minimum": 0},
        "lower_miss_count": {"type": "integer", "minimum": 0}, "upper_miss_count": {"type": "integer", "minimum": 0},
        "descriptive_only": {"const": true}, "small_sample_warning": {"const": true}}
    },
    "futureInterval": {
      "type": "object", "additionalProperties": false,
      "required": ["target_period", "residual_pool_count", "quantile_rank", "quantile_value", "point_forecast_raw",
        "lower_raw_unclipped", "lower_raw", "upper_raw", "lower_clipping_applied", "point_forecast_reported",
        "interval_lower_reported", "interval_upper_reported", "reporting_policy"],
      "properties": {"target_period": {"const": "2024-W26"}, "residual_pool_count": {"const": 68},
        "quantile_rank": {"type": "integer", "minimum": 1, "maximum": 68}, "quantile_value": {"type": "number", "minimum": 0},
        "point_forecast_raw": {"type": "number"}, "lower_raw_unclipped": {"type": "number"}, "lower_raw": {"type": "number", "minimum": 0},
        "upper_raw": {"type": "number"}, "lower_clipping_applied": {"type": "boolean"}, "point_forecast_reported": {"type": "integer", "minimum": 0},
        "interval_lower_reported": {"type": "integer", "minimum": 0}, "interval_upper_reported": {"type": "integer", "minimum": 0},
        "reporting_policy": {"const": "point_nearest_integer_python_round_half_to_even_bounds_outward_floor_ceiling"}}
    }
  }
}
