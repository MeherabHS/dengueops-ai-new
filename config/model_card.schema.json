{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dengueops.local/schemas/model_card.schema.json",
  "title": "DengueOps Model Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "model_card_schema_version", "model_card_id", "model_card_version", "model_id", "model_version",
    "deployment_id", "model_family", "estimator_library", "estimator_library_version", "target",
    "forecast_horizon", "feature_formula_ids", "selected_features", "training_period", "data_sources", "data_mode",
    "observed_data_mode", "validation_method", "baseline_models", "performance_metrics",
    "primary_validation_method", "rolling_validation_artifact_path", "rolling_validation_artifact_sha256",
    "rolling_validation_version", "rolling_fold_count", "rolling_initial_training_window", "rolling_step_weeks",
    "rolling_horizon_weeks", "rolling_aggregate_metrics", "rolling_baseline_comparison", "performance_variability",
    "native_importance_stability_status", "permutation_stability_status", "legacy_validation_method",
    "legacy_validation_artifact_path", "validation_limitations", "model_selection_status",
    "candidate_model_comparison_artifact_path", "candidate_model_comparison_artifact_sha256", "candidate_registry_version",
    "candidate_registry_sha256", "candidate_models", "primary_selection_metric", "selection_rule", "comparison_selected_model",
    "comparison_selected_model_reason", "selected_model_rank", "selected_model_fold_count", "selected_model_failures",
    "comparison_limitations", "selected_model_adoption_status", "current_forecast_model",
    "adoption_status", "adoption_policy_version", "adopted_model_parameters_sha256",
    "comparison_artifact_sha256", "active_model_family", "active_model_library", "active_model_library_version",
    "selected_model_explainability_status", "selected_model_explainability_artifact_path",
    "selected_model_explainability_artifact_sha256", "uncertainty_status", "uncertainty_method_version",
    "nominal_coverage", "observed_temporal_coverage", "covered_fold_count", "evaluated_fold_count",
    "calibration_warmup_fold_count", "interval_width_summary", "lower_miss_count", "upper_miss_count",
    "uncertainty_artifact_path", "uncertainty_artifact_sha256", "residual_source_artifact_path",
    "residual_source_artifact_sha256", "uncertainty_active_model_binding", "uncertainty_limitations",
    "operational_scenario_relationship", "retained_legacy_rmse_status", "is_prediction_interval", "calibrated_on_synthetic_data",
    "retained_legacy_gbr_evidence", "adoption_limitations", "forecast_artifact_sha256",
    "uncertainty_method", "limitations", "intended_use", "prohibited_uses", "maturity_statements",
    "deprecated_compatibility_fields", "formula_registry_version", "formula_registry_sha256",
    "deployment_profile_sha256", "evidence_registry_schema_version", "evidence_registry_sha256",
    "evidence_ids", "approval_record_ids", "approval_status", "deployment_gate",
    "explainability_status", "explainability_artifact_path", "explainability_artifact_sha256",
    "explainability_methods", "explainability_limitations", "importance_stability_status",
    "explainability_evaluation", "provenance", "generated_at"
  ],
  "properties": {
    "model_card_schema_version": {"const": "1.0"}, "model_card_id": {"$ref": "#/$defs/nonEmpty"},
    "model_card_version": {"$ref": "#/$defs/nonEmpty"}, "model_id": {"$ref": "#/$defs/nonEmpty"},
    "model_version": {"$ref": "#/$defs/nonEmpty"}, "deployment_id": {"$ref": "#/$defs/nonEmpty"},
    "model_family": {"$ref": "#/$defs/nonEmpty"}, "estimator_library": {"$ref": "#/$defs/nonEmpty"},
    "estimator_library_version": {"$ref": "#/$defs/nonEmpty"}, "target": {"$ref": "#/$defs/nonEmpty"},
    "forecast_horizon": {"type": "object", "additionalProperties": false, "required": ["value", "unit"], "properties": {"value": {"type": "integer", "minimum": 1}, "unit": {"enum": ["days", "weeks"]}}},
    "feature_formula_ids": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "minItems": 1, "uniqueItems": true},
    "selected_features": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "minItems": 1, "uniqueItems": true},
    "training_period": {"type": "object", "additionalProperties": false, "required": ["start", "end"], "properties": {"start": {"$ref": "#/$defs/period"}, "end": {"$ref": "#/$defs/period"}}},
    "data_sources": {"type": "object", "additionalProperties": false, "required": ["cases", "climate", "operational"], "properties": {"cases": {"$ref": "#/$defs/nonEmpty"}, "climate": {"$ref": "#/$defs/nonEmpty"}, "operational": {"$ref": "#/$defs/nonEmpty"}}},
    "data_mode": {"enum": ["synthetic_capability_demonstration", "research_candidate", "locally_calibrated_deployment", "institution_approved_deployment"]},
    "observed_data_mode": {"enum": ["synthetic", "real", "mixed"]},
    "validation_method": {"$ref": "#/$defs/nonEmpty"}, "baseline_models": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "minItems": 1},
    "performance_metrics": {"type": "object"}, "uncertainty_method": {"const": "prequential_expanding_absolute_residual_quantile"},
    "primary_validation_method": {"const": "expanding_window_rolling_origin"},
    "rolling_validation_artifact_path": {"const": "data/rolling_validation.json"},
    "rolling_validation_artifact_sha256": {"$ref": "#/$defs/sha256"},
    "rolling_validation_version": {"const": "p1.1-v1"}, "rolling_fold_count": {"const": 68},
    "rolling_initial_training_window": {"const": 104}, "rolling_step_weeks": {"const": 1}, "rolling_horizon_weeks": {"const": 2},
    "rolling_aggregate_metrics": {"type": "object"}, "rolling_baseline_comparison": {"type": "object"},
    "performance_variability": {"type": "object"}, "native_importance_stability_status": {"const": "not_evaluated_across_temporal_folds"},
    "permutation_stability_status": {"const": "not_evaluated_single_row_folds"},
    "legacy_validation_method": {"const": "time_based_holdout_final_20_percent"},
    "legacy_validation_artifact_path": {"const": "data/validation_metrics.json"},
    "validation_limitations": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "minItems": 1},
    "model_selection_status": {"const": "comparison_complete_and_adopted"},
    "candidate_model_comparison_artifact_path": {"type": ["string", "null"]},
    "candidate_model_comparison_artifact_sha256": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "candidate_registry_version": {"const": "p1.2a-v1"}, "candidate_registry_sha256": {"$ref": "#/$defs/sha256"},
    "candidate_models": {"type": "array", "minItems": 7, "maxItems": 7, "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmpty"}},
    "primary_selection_metric": {"const": "MAE"}, "selection_rule": {"$ref": "#/$defs/nonEmpty"},
    "comparison_selected_model": {"type": ["string", "null"]}, "comparison_selected_model_reason": {"type": ["string", "null"]},
    "selected_model_rank": {"type": ["integer", "null"]}, "selected_model_fold_count": {"type": ["integer", "null"]},
    "selected_model_failures": {"type": ["integer", "null"]}, "comparison_limitations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/nonEmpty"}},
    "selected_model_adoption_status": {"const": "adopted_p1.2b"}, "current_forecast_model": {"const": "random_forest"},
    "adoption_status": {"const": "adopted_p1.2b"}, "adoption_policy_version": {"const": "p1.2b-v1"},
    "adopted_model_parameters_sha256": {"$ref": "#/$defs/sha256"},
    "comparison_artifact_sha256": {"$ref": "#/$defs/sha256"},
    "active_model_family": {"const": "RandomForestRegressor"}, "active_model_library": {"const": "scikit-learn"},
    "active_model_library_version": {"$ref": "#/$defs/nonEmpty"},
    "selected_model_explainability_status": {"const": "generated_active_selected_model_diagnostic"},
    "selected_model_explainability_artifact_path": {"const": "data/selected_model_explainability.json"},
    "selected_model_explainability_artifact_sha256": {"$ref": "#/$defs/sha256"},
    "uncertainty_method_version": {"const": "p1.3-v1"},
    "uncertainty_status": {"const": "temporally_evaluated_synthetic_empirical_range"},
    "nominal_coverage": {"const": 0.9}, "observed_temporal_coverage": {"type": "number", "minimum": 0, "maximum": 1},
    "covered_fold_count": {"type": "integer", "minimum": 0}, "evaluated_fold_count": {"const": 48},
    "calibration_warmup_fold_count": {"const": 20}, "interval_width_summary": {"type": "object", "minProperties": 4},
    "lower_miss_count": {"type": "integer", "minimum": 0}, "upper_miss_count": {"type": "integer", "minimum": 0},
    "uncertainty_artifact_path": {"const": "data/forecast_uncertainty.json"}, "uncertainty_artifact_sha256": {"$ref": "#/$defs/sha256"},
    "residual_source_artifact_path": {"const": "data/candidate_model_comparison.json"}, "residual_source_artifact_sha256": {"$ref": "#/$defs/sha256"},
    "uncertainty_active_model_binding": {"type": "object", "minProperties": 4},
    "uncertainty_limitations": {"type": "array", "minItems": 5, "items": {"$ref": "#/$defs/nonEmpty"}},
    "operational_scenario_relationship": {"type": "object", "minProperties": 3},
    "retained_legacy_rmse_status": {"const": "operational_planning_compatibility_only_not_forecast_interval"},
    "is_prediction_interval": {"const": false}, "calibrated_on_synthetic_data": {"const": true},
    "retained_legacy_gbr_evidence": {"type": "object", "minProperties": 1},
    "adoption_limitations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/nonEmpty"}},
    "forecast_artifact_sha256": {"$ref": "#/$defs/sha256"},
    "limitations": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "minItems": 1},
    "intended_use": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "minItems": 1},
    "prohibited_uses": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "minItems": 1},
    "maturity_statements": {"type": "object"}, "deprecated_compatibility_fields": {"type": "object"},
    "formula_registry_version": {"$ref": "#/$defs/nonEmpty"}, "formula_registry_sha256": {"$ref": "#/$defs/sha256"},
    "deployment_profile_sha256": {"$ref": "#/$defs/sha256"}, "evidence_registry_schema_version": {"const": "1.0"},
    "evidence_registry_sha256": {"$ref": "#/$defs/sha256"}, "evidence_ids": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "uniqueItems": true},
    "approval_record_ids": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "uniqueItems": true},
    "approval_status": {"enum": ["not_approved", "approved"]},
    "deployment_gate": {"enum": ["benchmark_only", "research_candidate", "locally_backtested", "expert_reviewed", "institution_approved", "shadow_validated", "operational_advisory"]},
    "explainability_status": {"enum": ["generated", "not_generated"]},
    "explainability_artifact_path": {"const": "data/selected_model_explainability.json"},
    "explainability_artifact_sha256": {"$ref": "#/$defs/sha256"},
    "explainability_methods": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "minItems": 1, "uniqueItems": true},
    "explainability_limitations": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "minItems": 1},
    "importance_stability_status": {"const": "not_evaluated_across_temporal_folds"},
    "explainability_evaluation": {"$ref": "#/$defs/explainabilityEvaluation"},
    "provenance": {"type": "object"}, "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "period": {"type": "object", "additionalProperties": false, "required": ["epi_year", "epi_week"], "properties": {"epi_year": {"type": "integer"}, "epi_week": {"type": "integer", "minimum": 1, "maximum": 52}}},
    "periodRange": {"type": "object", "additionalProperties": false, "required": ["start", "end"], "properties": {"start": {"$ref": "#/$defs/period"}, "end": {"$ref": "#/$defs/period"}}},
    "explainabilityEvaluation": {
      "type": "object", "additionalProperties": false,
      "required": ["estimator_role", "training_period", "validation_period", "evaluation_split", "feature_order_sha256", "validation_matrix_sha256"],
      "properties": {
        "estimator_role": {"const": "selected_model_chronological_holdout_validation_instance"},
        "training_period": {"$ref": "#/$defs/periodRange"},
        "validation_period": {"$ref": "#/$defs/periodRange"},
        "evaluation_split": {"const": "legacy_final_chronological_20_percent"},
        "feature_order_sha256": {"$ref": "#/$defs/sha256"},
        "validation_matrix_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
